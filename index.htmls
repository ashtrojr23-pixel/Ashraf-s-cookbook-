<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ashraf's Cookbook — Kenyan & World Cuisine Recipes</title>

<!-- ═══ PRIMARY SEO ═══ -->
<meta name="description" content="Ashraf's Cookbook — the most comprehensive collection of authentic Kenyan recipes and world cuisine. From nyama choma, ugali, pilau and coastal dishes to Italian pasta, Japanese ramen, Indian biryani and more. Step-by-step recipes with photos.">
<meta name="keywords" content="Kenyan recipes, Kenyan food, ugali recipe, nyama choma, chapati, pilau, sukuma wiki, mandazi, chai Kenya, African cuisine, world recipes, international food, Nairobi street food, Swahili coast food, East African cooking">
<meta name="author" content="Ashraf's Cookbook">
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#0B2545">
<link rel="canonical" href="https://ashrafscookbook.com/">

<!-- ═══ OPEN GRAPH ═══ -->
<meta property="og:type" content="website">
<meta property="og:title" content="Ashraf's Cookbook — Kenyan & World Cuisine">
<meta property="og:description" content="75+ authentic Kenyan and international recipes with step-by-step instructions, ingredients, and chef tips.">
<meta property="og:image" content="https://images.unsplash.com/photo-1544025162-d76694265947?w=1200&q=80">
<meta property="og:url" content="https://ashrafscookbook.com/">
<meta property="og:site_name" content="Ashraf's Cookbook">
<meta property="og:locale" content="en_KE">

<!-- ═══ TWITTER CARD ═══ -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Ashraf's Cookbook — Kenyan & World Cuisine">
<meta name="twitter:description" content="75+ authentic recipes from Kenya and around the world.">
<meta name="twitter:image" content="https://images.unsplash.com/photo-1544025162-d76694265947?w=1200&q=80">

<!-- ═══ SCHEMA.ORG WEBSITE ═══ -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Ashraf's Cookbook",
  "url": "https://ashrafscookbook.com",
  "description": "Comprehensive collection of authentic Kenyan and world cuisine recipes",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://ashrafscookbook.com/#/search?q={search_term}",
    "query-input": "required name=search_term"
  }
}
</script>

<!-- ═══ FONTS ═══ -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&display=swap" rel="stylesheet">

<style>
/* ════════════════════════════════════════════
   CSS VARIABLES — MINT · SAGE · DARK NAVY
════════════════════════════════════════════ */
:root {
  --navy:         #0B2545;
  --navy-mid:     #163A6B;
  --navy-light:   #244E8A;
  --mint:         #2EC4B6;
  --mint-bright:  #22AFA2;
  --mint-light:   #7FD9D3;
  --mint-pale:    #C8F0ED;
  --mint-ghost:   #EAF9F8;
  --sage:         #52796F;
  --sage-mid:     #74A58C;
  --sage-light:   #A8C5B5;
  --sage-pale:    #D4E8DF;
  --sage-ghost:   #F0F7F4;
  --cream:        #F6FEFD;
  --white:        #FFFFFF;
  --text:         #0B2545;
  --text-body:    #2A4A6A;
  --text-light:   #5A7A95;
  --text-muted:   #8AAABB;
  --border:       rgba(46,196,182,0.18);
  --border-sage:  rgba(82,121,111,0.2);
  --shadow-sm:    0 2px 12px rgba(11,37,69,0.08);
  --shadow-md:    0 8px 32px rgba(11,37,69,0.12);
  --shadow-lg:    0 20px 60px rgba(11,37,69,0.18);
  --shadow-card:  0 4px 24px rgba(11,37,69,0.1);
}

/* ════════════════════════════════════════════
   RESET & BASE
════════════════════════════════════════════ */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; font-size:16px; }
body {
  font-family:'Outfit', sans-serif;
  background:var(--cream);
  color:var(--text);
  overflow-x:hidden;
  min-height:100vh;
}
img { display:block; max-width:100%; }
button { cursor:pointer; border:none; background:none; font-family:inherit; }
a { text-decoration:none; color:inherit; }
input { font-family:inherit; }

/* ════════════════════════════════════════════
   NAVIGATION
════════════════════════════════════════════ */
.nav {
  position:sticky; top:0; z-index:200;
  background:rgba(11,37,69,0.97);
  backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(46,196,182,0.2);
}
.nav-inner {
  max-width:1400px; margin:0 auto;
  padding:0 28px;
  display:flex; align-items:center; gap:12px;
  height:68px; overflow-x:auto;
  scrollbar-width:none;
}
.nav-inner::-webkit-scrollbar { display:none; }
.nav-logo {
  display:flex; align-items:center; gap:0;
  flex-shrink:0; margin-right:16px; cursor:pointer;
}
.logo-a-wrapper {
  position:relative;
  display:inline-flex;
  flex-direction:column;
  align-items:center;
  margin-right:0;
}
.logo-chef-hat {
  width:26px; height:20px;
  display:block; margin-bottom:-2px;
  flex-shrink:0;
}
.logo-a-letter {
  font-family:'Playfair Display', serif;
  font-size:26px; font-weight:900;
  color:var(--mint); line-height:1;
  display:inline-block;
}
.logo-text-rest {
  font-family:'Playfair Display', serif;
  font-size:20px; font-weight:700;
  color:var(--white); letter-spacing:-0.3px;
  white-space:nowrap; line-height:1;
  padding-bottom:1px;
  align-self:flex-end;
}
.nav-links {
  display:flex; gap:6px; align-items:center;
}
.nav-pill {
  padding:7px 16px; border-radius:100px;
  font-size:13px; font-weight:500;
  color:rgba(255,255,255,0.65);
  border:1px solid rgba(255,255,255,0.1);
  transition:all 0.2s; white-space:nowrap;
  background:transparent;
}
.nav-pill:hover, .nav-pill.active {
  background:var(--mint);
  border-color:var(--mint);
  color:var(--navy);
  font-weight:600;
}
.nav-search-btn {
  margin-left:auto; flex-shrink:0;
  width:38px; height:38px;
  border-radius:50%;
  border:1px solid rgba(46,196,182,0.3);
  color:var(--mint-light);
  font-size:16px;
  display:flex; align-items:center; justify-content:center;
  transition:all 0.2s;
}
.nav-search-btn:hover { background:var(--mint); color:var(--navy); }

/* ════════════════════════════════════════════
   PAGE SYSTEM
════════════════════════════════════════════ */
.page { display:none; }
.page.active { display:block; }

/* ════════════════════════════════════════════
   HERO
════════════════════════════════════════════ */
.hero {
  min-height:92vh;
  background:
    radial-gradient(ellipse at 20% 60%, rgba(46,196,182,0.18) 0%, transparent 55%),
    radial-gradient(ellipse at 85% 15%, rgba(82,121,111,0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 60% 90%, rgba(22,58,107,0.3) 0%, transparent 60%),
    linear-gradient(145deg, #060E1C 0%, #0B2545 35%, #163A6B 65%, #0F2E56 100%);
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  text-align:center; padding:60px 24px;
  position:relative; overflow:hidden;
}
.hero::before {
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(circle at 10% 20%, rgba(46,196,182,0.06) 0%, transparent 40%),
    url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%232EC4B6' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  pointer-events:none;
}
.hero-badge {
  font-size:11px; font-weight:700; letter-spacing:4px;
  text-transform:uppercase; color:var(--mint);
  border:1px solid rgba(46,196,182,0.35);
  padding:8px 22px; border-radius:100px;
  margin-bottom:36px; position:relative;
  animation:fadeUp 0.7s ease both;
}
.hero-logo-big {
  display:flex; align-items:flex-end; justify-content:center;
  gap:0; margin-bottom:12px;
  animation:fadeUp 0.7s 0.1s ease both;
  position:relative;
}
.hero-a-wrap {
  display:inline-flex; flex-direction:column;
  align-items:center; position:relative;
}
.hero-hat-svg {
  width:52px; height:38px; margin-bottom:-6px;
}
.hero-a {
  font-family:'Playfair Display', serif;
  font-size:clamp(72px,11vw,130px);
  font-weight:900; color:var(--mint);
  line-height:0.9;
}
.hero-title-rest {
  font-family:'Playfair Display', serif;
  font-size:clamp(72px,11vw,130px);
  font-weight:900; color:var(--white);
  line-height:0.9; letter-spacing:-2px;
}
.hero-sub-title {
  font-family:'Playfair Display', serif;
  font-size:clamp(20px,3.5vw,36px);
  font-weight:700; font-style:italic;
  color:var(--mint-light);
  margin-bottom:8px;
  animation:fadeUp 0.7s 0.15s ease both;
}
.hero-desc {
  font-family:'Lora', serif;
  font-size:clamp(15px,2vw,19px);
  font-weight:400; font-style:italic;
  color:rgba(200,240,237,0.7);
  max-width:560px; line-height:1.65;
  margin-bottom:40px;
  animation:fadeUp 0.7s 0.2s ease both;
}
.hero-stats {
  display:flex; gap:48px;
  margin-bottom:48px;
  animation:fadeUp 0.7s 0.25s ease both;
}
.hero-stat-num {
  font-family:'Playfair Display', serif;
  font-size:44px; font-weight:900;
  color:var(--mint); line-height:1;
}
.hero-stat-label {
  font-size:11px; letter-spacing:3px;
  text-transform:uppercase;
  color:rgba(200,240,237,0.45);
  margin-top:4px;
}
.hero-cta-row {
  display:flex; gap:14px; flex-wrap:wrap;
  justify-content:center;
  animation:fadeUp 0.7s 0.3s ease both;
}
.btn-primary {
  padding:14px 32px; border-radius:100px;
  background:linear-gradient(135deg, var(--mint), var(--mint-bright));
  color:var(--navy); font-weight:700; font-size:15px;
  letter-spacing:0.3px; transition:all 0.2s;
  box-shadow:0 4px 24px rgba(46,196,182,0.35);
}
.btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 32px rgba(46,196,182,0.45); }
.btn-outline {
  padding:14px 32px; border-radius:100px;
  border:1.5px solid rgba(46,196,182,0.4);
  color:var(--mint-light); font-weight:600; font-size:15px;
  transition:all 0.2s;
}
.btn-outline:hover { border-color:var(--mint); color:var(--mint); background:rgba(46,196,182,0.08); }
.hero-scroll {
  position:absolute; bottom:32px;
  font-size:11px; letter-spacing:3px;
  text-transform:uppercase;
  color:rgba(200,240,237,0.3);
  animation:bounce 2.5s infinite;
}

/* ════════════════════════════════════════════
   CATEGORY STRIP
════════════════════════════════════════════ */
.cat-strip {
  background:var(--navy);
  border-bottom:1px solid rgba(46,196,182,0.15);
  padding:0 28px;
}
.cat-strip-inner {
  max-width:1400px; margin:0 auto;
  display:flex; gap:8px; padding:16px 0;
  overflow-x:auto; scrollbar-width:none;
}
.cat-strip-inner::-webkit-scrollbar { display:none; }
.cat-chip {
  padding:9px 20px; border-radius:100px;
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.1);
  color:rgba(255,255,255,0.6);
  font-size:13px; font-weight:500;
  white-space:nowrap; transition:all 0.2s;
  display:flex; align-items:center; gap:7px;
}
.cat-chip:hover, .cat-chip.active {
  background:rgba(46,196,182,0.15);
  border-color:var(--mint);
  color:var(--mint);
}

/* ════════════════════════════════════════════
   SEARCH BAR
════════════════════════════════════════════ */
.search-bar-wrap {
  max-width:680px; margin:0 auto;
  padding:52px 24px 0;
}
.search-bar-inner {
  position:relative;
}
.search-input {
  width:100%; padding:18px 60px 18px 24px;
  border-radius:100px;
  border:2px solid var(--border);
  background:white;
  font-size:16px; color:var(--text);
  outline:none; transition:border-color 0.2s;
  box-shadow:var(--shadow-md);
}
.search-input:focus { border-color:var(--mint); }
.search-input::placeholder { color:var(--text-muted); }
.search-icon-btn {
  position:absolute; right:6px; top:50%;
  transform:translateY(-50%);
  width:44px; height:44px; border-radius:50%;
  background:var(--mint); color:var(--navy);
  font-size:18px; display:flex;
  align-items:center; justify-content:center;
}
.search-count {
  text-align:center; margin-top:14px;
  font-size:13px; color:var(--text-light);
  font-style:italic;
}

/* ════════════════════════════════════════════
   SECTION HEADER
════════════════════════════════════════════ */
.section { max-width:1400px; margin:0 auto; padding:64px 28px 36px; }
.section-head {
  display:flex; align-items:baseline;
  gap:14px; margin-bottom:36px;
  border-bottom:2px solid var(--border);
  padding-bottom:20px;
}
.section-emoji { font-size:34px; }
.section-title {
  font-family:'Playfair Display', serif;
  font-size:clamp(26px,3.5vw,40px);
  font-weight:900; color:var(--navy);
}
.section-count {
  font-size:13px; color:var(--text-light);
  background:var(--mint-ghost);
  padding:4px 14px; border-radius:100px;
  border:1px solid var(--border);
}

/* ════════════════════════════════════════════
   DISH GRID / CARDS
════════════════════════════════════════════ */
.dish-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(300px,1fr));
  gap:24px;
}
.dish-card {
  background:white; border-radius:20px;
  overflow:hidden;
  box-shadow:var(--shadow-card);
  cursor:pointer;
  transition:transform 0.3s cubic-bezier(.34,1.56,.64,1), box-shadow 0.3s;
  border:1px solid rgba(46,196,182,0.1);
}
.dish-card:hover {
  transform:translateY(-7px);
  box-shadow:0 16px 50px rgba(11,37,69,0.18);
}
.dish-card-img {
  width:100%; height:210px;
  object-fit:cover; display:block;
  position:relative;
}
.dish-card-img-wrap {
  position:relative; overflow:hidden; height:210px;
}
.dish-card-img-wrap img {
  width:100%; height:100%;
  object-fit:cover; display:block;
  transition:transform 0.4s;
}
.dish-card:hover .dish-card-img-wrap img { transform:scale(1.06); }
.dish-card-origin {
  position:absolute; top:12px; right:12px;
  background:rgba(11,37,69,0.82);
  backdrop-filter:blur(8px);
  color:white; font-size:11px;
  font-weight:600; letter-spacing:1.5px;
  text-transform:uppercase;
  padding:5px 12px; border-radius:100px;
  border:1px solid rgba(46,196,182,0.3);
}
.dish-card-body { padding:20px; }
.dish-card-tags { display:flex; gap:5px; flex-wrap:wrap; margin-bottom:10px; }
.tag {
  font-size:10px; font-weight:700;
  letter-spacing:1px; text-transform:uppercase;
  padding:3px 10px; border-radius:100px;
}
.tag-kenyan  { background:rgba(46,196,182,0.1); color:var(--mint-bright); border:1px solid rgba(46,196,182,0.25); }
.tag-coastal { background:rgba(22,58,107,0.08); color:var(--navy-light); border:1px solid rgba(22,58,107,0.15); }
.tag-street  { background:rgba(82,121,111,0.1); color:var(--sage); border:1px solid rgba(82,121,111,0.2); }
.tag-snack   { background:rgba(255,184,0,0.1); color:#9B6A00; border:1px solid rgba(255,184,0,0.2); }
.tag-drink   { background:rgba(34,175,162,0.08); color:#0F7B72; border:1px solid rgba(34,175,162,0.2); }
.tag-breakfast { background:rgba(116,165,140,0.1); color:var(--sage); border:1px solid rgba(116,165,140,0.2); }
.tag-international { background:rgba(36,78,138,0.1); color:var(--navy-mid); border:1px solid rgba(36,78,138,0.2); }
.tag-veg { background:rgba(82,121,111,0.12); color:var(--sage); border:1px solid rgba(82,121,111,0.25); }
.dish-card-name {
  font-family:'Playfair Display', serif;
  font-size:21px; font-weight:700;
  color:var(--navy); margin-bottom:5px; line-height:1.2;
}
.dish-card-origin-name {
  font-family:'Lora', serif;
  font-size:13px; font-style:italic;
  color:var(--mint-bright); margin-bottom:9px;
}
.dish-card-desc {
  font-size:13.5px; color:var(--text-body);
  line-height:1.6; margin-bottom:16px;
}
.dish-card-meta {
  display:flex; gap:14px; font-size:12px;
  color:var(--text-light);
  border-top:1px solid var(--border);
  padding-top:14px; flex-wrap:wrap;
}
.dish-card-meta span { display:flex; align-items:center; gap:4px; }
.dish-card-btn {
  margin-top:14px; width:100%;
  padding:11px 0; border-radius:12px;
  background:linear-gradient(135deg, var(--navy), var(--navy-mid));
  color:white; font-size:14px; font-weight:600;
  letter-spacing:0.4px; transition:all 0.2s;
}
.dish-card-btn:hover { background:linear-gradient(135deg, var(--mint), var(--mint-bright)); color:var(--navy); }

/* ════════════════════════════════════════════
   RECIPE PAGE (individual)
════════════════════════════════════════════ */
.recipe-hero {
  width:100%; height:clamp(340px,50vh,560px);
  position:relative; overflow:hidden;
}
.recipe-hero img {
  width:100%; height:100%; object-fit:cover; display:block;
}
.recipe-hero-overlay {
  position:absolute; inset:0;
  background:linear-gradient(to bottom, rgba(11,37,69,0.2) 0%, rgba(11,37,69,0.8) 100%);
}
.recipe-hero-content {
  position:absolute; bottom:0; left:0; right:0;
  padding:40px 48px;
  max-width:1000px;
}
.recipe-breadcrumb {
  font-size:12px; color:rgba(200,240,237,0.65);
  margin-bottom:14px; display:flex; align-items:center; gap:6px;
}
.recipe-breadcrumb a { color:var(--mint-light); cursor:pointer; }
.recipe-breadcrumb a:hover { color:var(--mint); }
.recipe-main-tag {
  display:inline-block; margin-bottom:10px;
  font-size:11px; font-weight:700; letter-spacing:2px;
  text-transform:uppercase; color:var(--mint);
  border:1px solid rgba(46,196,182,0.4);
  padding:5px 14px; border-radius:100px;
  background:rgba(11,37,69,0.5); backdrop-filter:blur(10px);
}
.recipe-page-title {
  font-family:'Playfair Display', serif;
  font-size:clamp(30px,5vw,58px);
  font-weight:900; color:white;
  line-height:1.05; margin-bottom:8px;
}
.recipe-page-subtitle {
  font-family:'Lora', serif;
  font-size:clamp(15px,2vw,20px);
  font-style:italic; color:var(--mint-light);
}
.recipe-body-wrap {
  max-width:1000px; margin:0 auto;
  padding:48px 28px 80px;
}
.recipe-meta-bar {
  display:flex; gap:0;
  background:white; border-radius:16px;
  border:1px solid var(--border);
  box-shadow:var(--shadow-sm);
  margin-bottom:40px; overflow:hidden;
}
.recipe-meta-item {
  flex:1; padding:20px 16px; text-align:center;
  border-right:1px solid var(--border);
}
.recipe-meta-item:last-child { border-right:none; }
.recipe-meta-icon { font-size:22px; margin-bottom:6px; }
.recipe-meta-val {
  font-family:'Playfair Display', serif;
  font-size:16px; font-weight:700; color:var(--navy);
}
.recipe-meta-label {
  font-size:10px; text-transform:uppercase;
  letter-spacing:1.5px; color:var(--text-muted);
  margin-top:2px;
}
.recipe-desc-block {
  font-family:'Lora', serif;
  font-size:17px; line-height:1.8;
  color:var(--text-body);
  border-left:3px solid var(--mint);
  padding-left:20px; margin-bottom:40px;
}
.recipe-two-col {
  display:grid; grid-template-columns:1fr 1.7fr;
  gap:36px; align-items:start;
}
@media(max-width:700px) { .recipe-two-col { grid-template-columns:1fr; } }
.recipe-section-title {
  font-family:'Playfair Display', serif;
  font-size:22px; font-weight:700;
  color:var(--navy); margin-bottom:20px;
  display:flex; align-items:center; gap:10px;
  padding-bottom:12px;
  border-bottom:2px solid var(--border);
}
.ingr-card {
  background:white; border-radius:16px;
  padding:28px; border:1px solid var(--border);
  box-shadow:var(--shadow-sm);
  position:sticky; top:84px;
}
.ingr-list { list-style:none; display:flex; flex-direction:column; gap:10px; }
.ingr-item {
  display:flex; align-items:flex-start; gap:10px;
  font-size:14.5px; color:var(--text-body);
  padding:10px 12px; background:var(--mint-ghost);
  border-radius:10px; line-height:1.45;
}
.ingr-dot {
  width:8px; height:8px; border-radius:50%;
  background:var(--mint); flex-shrink:0;
  margin-top:5px;
}
.steps-card {
  background:white; border-radius:16px;
  padding:28px; border:1px solid var(--border);
  box-shadow:var(--shadow-sm);
}
.steps-list { list-style:none; display:flex; flex-direction:column; gap:16px; }
.step-item { display:flex; gap:18px; align-items:flex-start; }
.step-num {
  width:36px; height:36px; border-radius:50%;
  background:linear-gradient(135deg, var(--mint), var(--mint-bright));
  color:var(--navy); font-family:'Playfair Display', serif;
  font-size:16px; font-weight:700;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; box-shadow:0 4px 12px rgba(46,196,182,0.35);
}
.step-text { font-size:15px; line-height:1.7; color:var(--text-body); padding-top:6px; }
.tips-block {
  background:linear-gradient(135deg, var(--sage-ghost), var(--mint-ghost));
  border:1px solid var(--border-sage);
  border-radius:16px; padding:24px; margin-top:32px;
}
.tips-title {
  font-family:'Playfair Display', serif;
  font-size:17px; font-weight:700; color:var(--sage);
  margin-bottom:10px; display:flex; align-items:center; gap:8px;
}
.tips-text { font-size:14.5px; line-height:1.7; color:var(--text-body); }
.recipe-back-btn {
  display:inline-flex; align-items:center; gap:8px;
  color:var(--mint); font-size:14px; font-weight:600;
  cursor:pointer; margin-bottom:32px;
  padding:10px 20px; border-radius:100px;
  border:1px solid rgba(46,196,182,0.3);
  background:rgba(46,196,182,0.06);
  transition:all 0.2s;
}
.recipe-back-btn:hover { background:rgba(46,196,182,0.12); border-color:var(--mint); }
.recipe-actions {
  display:flex; gap:10px; margin-bottom:40px; flex-wrap:wrap;
}
.action-btn {
  padding:10px 20px; border-radius:100px;
  font-size:13px; font-weight:600;
  display:flex; align-items:center; gap:8px;
  transition:all 0.2s;
}
.action-btn-print { background:var(--navy); color:white; }
.action-btn-print:hover { background:var(--navy-mid); }
.action-btn-save { background:var(--mint-ghost); color:var(--mint-bright); border:1px solid var(--border); }
.action-btn-save:hover { background:var(--mint); color:var(--navy); }

/* Related dishes */
.related-section { margin-top:56px; }
.related-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(240px,1fr)); gap:20px; margin-top:24px; }
.related-card {
  background:white; border-radius:14px;
  overflow:hidden; cursor:pointer;
  border:1px solid var(--border);
  transition:transform 0.25s, box-shadow 0.25s;
}
.related-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-md); }
.related-card-img { width:100%; height:140px; object-fit:cover; }
.related-card-body { padding:14px; }
.related-card-name {
  font-family:'Playfair Display', serif;
  font-size:16px; font-weight:700; color:var(--navy);
}
.related-card-cat { font-size:12px; color:var(--text-muted); margin-top:4px; }

/* ════════════════════════════════════════════
   FEATURED SECTION
════════════════════════════════════════════ */
.featured-section { background:var(--navy); padding:80px 0; }
.featured-inner { max-width:1400px; margin:0 auto; padding:0 28px; }
.featured-head { text-align:center; margin-bottom:52px; }
.featured-head-label {
  font-size:11px; letter-spacing:4px; font-weight:700;
  text-transform:uppercase; color:var(--mint);
  margin-bottom:14px; display:block;
}
.featured-head-title {
  font-family:'Playfair Display', serif;
  font-size:clamp(30px,5vw,50px);
  font-weight:900; color:white; line-height:1.1;
}
.featured-head-title span { color:var(--mint); font-style:italic; }
.featured-grid {
  display:grid; grid-template-columns:repeat(auto-fill, minmax(320px,1fr));
  gap:24px;
}
.featured-card {
  border-radius:20px; overflow:hidden;
  cursor:pointer; position:relative;
  height:340px;
  transition:transform 0.3s;
}
.featured-card:hover { transform:scale(1.02); }
.featured-card img {
  width:100%; height:100%; object-fit:cover; display:block;
}
.featured-card-overlay {
  position:absolute; inset:0;
  background:linear-gradient(to top, rgba(11,37,69,0.92) 0%, rgba(11,37,69,0.1) 60%);
  display:flex; flex-direction:column;
  justify-content:flex-end; padding:28px;
}
.featured-card-tag {
  font-size:10px; letter-spacing:2px;
  text-transform:uppercase; color:var(--mint);
  font-weight:700; margin-bottom:8px;
}
.featured-card-name {
  font-family:'Playfair Display', serif;
  font-size:24px; font-weight:900;
  color:white; line-height:1.15; margin-bottom:6px;
}
.featured-card-desc {
  font-size:13px; color:rgba(200,240,237,0.75);
  line-height:1.5; margin-bottom:14px;
}
.featured-card-btn {
  display:inline-flex; align-items:center; gap:6px;
  color:var(--mint); font-size:13px; font-weight:600;
  border:1px solid rgba(46,196,182,0.4);
  padding:8px 18px; border-radius:100px;
  background:rgba(11,37,69,0.5); backdrop-filter:blur(8px);
  transition:all 0.2s; width:fit-content;
}
.featured-card-btn:hover { background:var(--mint); color:var(--navy); }

/* ════════════════════════════════════════════
   WORLD CUISINE BANNER
════════════════════════════════════════════ */
.world-banner {
  background:linear-gradient(135deg, var(--sage), #3D6B58);
  padding:70px 28px; text-align:center;
}
.world-banner-title {
  font-family:'Playfair Display', serif;
  font-size:clamp(26px,4vw,44px);
  font-weight:900; color:white; margin-bottom:12px;
}
.world-banner-desc {
  font-family:'Lora', serif;
  font-size:17px; font-style:italic;
  color:rgba(255,255,255,0.8);
  max-width:560px; margin:0 auto 28px;
  line-height:1.7;
}
.world-flags {
  display:flex; justify-content:center; flex-wrap:wrap;
  gap:10px; margin-bottom:28px;
}
.flag-chip {
  background:rgba(255,255,255,0.15);
  border:1px solid rgba(255,255,255,0.25);
  color:white; font-size:15px;
  padding:8px 18px; border-radius:100px;
  display:flex; align-items:center; gap:7px;
  cursor:pointer; transition:all 0.2s;
}
.flag-chip:hover { background:rgba(255,255,255,0.25); }

/* ════════════════════════════════════════════
   NO RESULTS
════════════════════════════════════════════ */
.no-results {
  text-align:center; padding:80px 24px;
  color:var(--text-light);
}
.no-results-emoji { font-size:64px; margin-bottom:16px; }
.no-results-title {
  font-family:'Playfair Display', serif;
  font-size:26px; color:var(--navy); margin-bottom:8px;
}

/* ════════════════════════════════════════════
   FOOTER
════════════════════════════════════════════ */
.footer {
  background:var(--navy);
  border-top:1px solid rgba(46,196,182,0.12);
  padding:60px 28px 40px;
  text-align:center;
}
.footer-logo {
  display:flex; align-items:center; justify-content:center;
  margin-bottom:16px;
}
.footer-logo-a {
  font-family:'Playfair Display', serif;
  font-size:32px; font-weight:900; color:var(--mint);
}
.footer-logo-rest {
  font-family:'Playfair Display', serif;
  font-size:26px; font-weight:700; color:white;
}
.footer-desc {
  font-family:'Lora', serif;
  font-size:15px; font-style:italic;
  color:rgba(200,240,237,0.5);
  max-width:480px; margin:0 auto 24px;
  line-height:1.7;
}
.footer-cats {
  display:flex; justify-content:center; flex-wrap:wrap;
  gap:8px; margin-bottom:32px;
}
.footer-cat {
  font-size:12px; color:rgba(200,240,237,0.4);
  padding:6px 16px; border-radius:100px;
  border:1px solid rgba(46,196,182,0.12);
  cursor:pointer; transition:all 0.2s;
}
.footer-cat:hover { color:var(--mint); border-color:rgba(46,196,182,0.35); }
.footer-copy {
  font-size:13px; color:rgba(200,240,237,0.25);
  border-top:1px solid rgba(46,196,182,0.1);
  padding-top:24px;
}

/* ════════════════════════════════════════════
   PRINT STYLES
════════════════════════════════════════════ */
@media print {
  .nav, .recipe-back-btn, .recipe-actions, .related-section, .footer { display:none !important; }
  .recipe-hero { height:300px; }
  body { font-size:12px; }
  .recipe-body-wrap { padding:20px; }
}

/* ════════════════════════════════════════════
   ANIMATIONS
════════════════════════════════════════════ */
@keyframes fadeUp {
  from { opacity:0; transform:translateY(22px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes bounce {
  0%,100% { transform:translateY(0); }
  50%     { transform:translateY(9px); }
}
@keyframes fadeIn {
  from { opacity:0; }
  to   { opacity:1; }
}

/* ════════════════════════════════════════════
   RESPONSIVE
════════════════════════════════════════════ */
@media(max-width:768px) {
  .hero-stats { gap:24px; }
  .hero-title-rest { font-size:64px; }
  .hero-a { font-size:64px; }
  .recipe-hero-content { padding:24px 20px; }
  .recipe-meta-bar { flex-wrap:wrap; }
  .recipe-meta-item { min-width:50%; }
  .dish-grid { grid-template-columns:1fr; }
  .hero-cta-row button { width:100%; max-width:280px; }
}
@media(max-width:480px) {
  .hero-stats { gap:16px; }
  .hero-stat-num { font-size:32px; }
  .section { padding:40px 16px 24px; }
}

/* ════════════════════════════════════════════
   DIVIDER
════════════════════════════════════════════ */
.section-divider {
  max-width:1400px; margin:0 auto;
  border:none; border-top:1px solid rgba(46,196,182,0.1);
}

/* image fallback bg */
.img-fallback {
  width:100%; height:100%;
  display:flex; align-items:center; justify-content:center;
  font-size:64px; background:var(--mint-pale);
}
</style>
</head>
<body>

<!-- ══════════════════════════════════════════
     NAVIGATION
══════════════════════════════════════════ -->
<nav class="nav">
  <div class="nav-inner">
    <div class="nav-logo" onclick="goHome()">
      <div class="logo-a-wrapper">
        <!-- Chef's Hat SVG on the A -->
        <svg class="logo-chef-hat" viewBox="0 0 52 38" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="26" cy="30" rx="20" ry="6" fill="white"/>
          <circle cx="26" cy="17" r="12" fill="white"/>
          <circle cx="14" cy="22" r="9" fill="white"/>
          <circle cx="38" cy="22" r="9" fill="white"/>
          <rect x="10" y="28" width="32" height="7" rx="2" fill="white"/>
          <rect x="10" y="32" width="32" height="3" rx="1" fill="rgba(11,37,69,0.12)"/>
          <circle cx="26" cy="5" r="4" fill="#2EC4B6"/>
        </svg>
        <span class="logo-a-letter">A</span>
      </div>
      <span class="logo-text-rest">shraf's Cookbook</span>
    </div>
    <div class="nav-links" id="navLinks">
      <button class="nav-pill active" data-cat="all" onclick="filterCat('all',this)">All Recipes</button>
      <button class="nav-pill" data-cat="kenyan" onclick="filterCat('kenyan',this)">🇰🇪 Kenyan</button>
      <button class="nav-pill" data-cat="street" onclick="filterCat('street',this)">🌽 Street Food</button>
      <button class="nav-pill" data-cat="coastal" onclick="filterCat('coastal',this)">🐚 Coastal</button>
      <button class="nav-pill" data-cat="snack" onclick="filterCat('snack',this)">🥟 Snacks</button>
      <button class="nav-pill" data-cat="drink" onclick="filterCat('drink',this)">☕ Drinks</button>
      <button class="nav-pill" data-cat="international" onclick="filterCat('international',this)">🌍 International</button>
    </div>
    <button class="nav-search-btn" onclick="focusSearch()">🔍</button>
  </div>
</nav>

<!-- ══════════════════════════════════════════
     PAGE: HOME
══════════════════════════════════════════ -->
<div class="page active" id="page-home">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge">🍴 75+ Authentic Recipes · Kenyan & World Cuisine</div>
    
    <div class="hero-logo-big">
      <div class="hero-a-wrap">
        <!-- Large chef's hat SVG for hero -->
        <svg class="hero-hat-svg" viewBox="0 0 104 72" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="52" cy="58" rx="40" ry="11" fill="white" opacity="0.95"/>
          <circle cx="52" cy="32" r="24" fill="white" opacity="0.95"/>
          <circle cx="27" cy="42" r="18" fill="white" opacity="0.95"/>
          <circle cx="77" cy="42" r="18" fill="white" opacity="0.95"/>
          <rect x="18" y="54" width="68" height="14" rx="3" fill="white" opacity="0.95"/>
          <rect x="18" y="62" width="68" height="6" rx="2" fill="rgba(11,37,69,0.1)"/>
          <circle cx="52" cy="8" r="7" fill="#2EC4B6"/>
          <circle cx="35" cy="14" r="4" fill="#7FD9D3" opacity="0.7"/>
          <circle cx="69" cy="14" r="4" fill="#7FD9D3" opacity="0.7"/>
        </svg>
        <span class="hero-a">A</span>
      </div>
      <span class="hero-title-rest">shraf's</span>
    </div>

    <div class="hero-sub-title">Cookbook</div>
    <p class="hero-desc">From the streets of Nairobi to the kitchens of the world — every recipe, every flavour, every story.</p>

    <div class="hero-stats">
      <div style="text-align:center">
        <div class="hero-stat-num">75+</div>
        <div class="hero-stat-label">Recipes</div>
      </div>
      <div style="text-align:center">
        <div class="hero-stat-num">8</div>
        <div class="hero-stat-label">Cuisines</div>
      </div>
      <div style="text-align:center">
        <div class="hero-stat-num">6</div>
        <div class="hero-stat-label">Categories</div>
      </div>
    </div>

    <div class="hero-cta-row">
      <button class="btn-primary" onclick="filterCat('kenyan',null);scrollToGrid()">🇰🇪 Kenyan Recipes</button>
      <button class="btn-outline" onclick="filterCat('international',null);scrollToGrid()">🌍 World Cuisine</button>
    </div>
    <div class="hero-scroll">Scroll to explore</div>
  </section>

  <!-- CATEGORY STRIP -->
  <div class="cat-strip">
    <div class="cat-strip-inner">
      <button class="cat-chip active" data-cat="all" onclick="filterCat('all',this)">🍽 All Dishes</button>
      <button class="cat-chip" data-cat="kenyan" onclick="filterCat('kenyan',this)">🇰🇪 Kenyan Mains</button>
      <button class="cat-chip" data-cat="street" onclick="filterCat('street',this)">🌽 Street Food</button>
      <button class="cat-chip" data-cat="coastal" onclick="filterCat('coastal',this)">🐚 Coastal Swahili</button>
      <button class="cat-chip" data-cat="breakfast" onclick="filterCat('breakfast',this)">🌅 Breakfast</button>
      <button class="cat-chip" data-cat="snack" onclick="filterCat('snack',this)">🥟 Snacks</button>
      <button class="cat-chip" data-cat="drink" onclick="filterCat('drink',this)">☕ Drinks</button>
      <button class="cat-chip" data-cat="international" onclick="filterCat('international',this)">🌍 International</button>
    </div>
  </div>

  <!-- SEARCH -->
  <div class="search-bar-wrap" id="searchWrap">
    <div class="search-bar-inner">
      <input type="text" class="search-input" id="searchInput" placeholder="Search ugali, pasta, ramen, chai..." oninput="handleSearch(this.value)">
      <button class="search-icon-btn">🔍</button>
    </div>
    <div class="search-count" id="searchCount"></div>
  </div>

  <!-- FEATURED SECTION -->
  <section class="featured-section" id="featuredSection">
    <div class="featured-inner">
      <div class="featured-head">
        <span class="featured-head-label">Chef's Picks</span>
        <h2 class="featured-head-title">Signature <span>Dishes</span></h2>
      </div>
      <div class="featured-grid" id="featuredGrid"></div>
    </div>
  </section>

  <!-- WORLD CUISINE BANNER -->
  <section class="world-banner">
    <h2 class="world-banner-title">🌍 World Cuisine Collection</h2>
    <p class="world-banner-desc">From Italian kitchens to Japanese ramen bars — explore global flavours all in one place.</p>
    <div class="world-flags">
      <span class="flag-chip" onclick="filterCat('italian',null)">🇮🇹 Italian</span>
      <span class="flag-chip" onclick="filterCat('indian',null)">🇮🇳 Indian</span>
      <span class="flag-chip" onclick="filterCat('japanese',null)">🇯🇵 Japanese</span>
      <span class="flag-chip" onclick="filterCat('mexican',null)">🇲🇽 Mexican</span>
      <span class="flag-chip" onclick="filterCat('chinese',null)">🇨🇳 Chinese</span>
      <span class="flag-chip" onclick="filterCat('thai',null)">🇹🇭 Thai</span>
      <span class="flag-chip" onclick="filterCat('french',null)">🇫🇷 French</span>
      <span class="flag-chip" onclick="filterCat('american',null)">🇺🇸 American</span>
      <span class="flag-chip" onclick="filterCat('middle-eastern',null)">🌙 Middle Eastern</span>
    </div>
    <button class="btn-primary" onclick="filterCat('international',null);scrollToGrid()">Explore All International</button>
  </section>

  <!-- MAIN DISH GRID -->
  <div id="gridAnchor"></div>
  <div id="dishSections"></div>

</div><!-- /page-home -->


<!-- ══════════════════════════════════════════
     PAGE: RECIPE
══════════════════════════════════════════ -->
<div class="page" id="page-recipe">
  <div id="recipe-content"></div>
</div>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-logo">
    <span class="footer-logo-a">A</span>
    <span class="footer-logo-rest">shraf's Cookbook</span>
  </div>
  <p class="footer-desc">Celebrating the flavours of Kenya and the world — authentic recipes passed down through generations and discovered across continents.</p>
  <div class="footer-cats">
    <span class="footer-cat" onclick="filterCat('kenyan',null)">🇰🇪 Kenyan</span>
    <span class="footer-cat" onclick="filterCat('street',null)">🌽 Street Food</span>
    <span class="footer-cat" onclick="filterCat('coastal',null)">🐚 Coastal</span>
    <span class="footer-cat" onclick="filterCat('snack',null)">🥟 Snacks</span>
    <span class="footer-cat" onclick="filterCat('drink',null)">☕ Drinks</span>
    <span class="footer-cat" onclick="filterCat('international',null)">🌍 International</span>
  </div>
  <p class="footer-copy">© 2025 Ashraf's Cookbook · All Recipes · Karibu Mezani 🍽</p>
</footer>

<script>
// ════════════════════════════════════════════════════════════════
//  DISH DATA — 75 recipes
// ════════════════════════════════════════════════════════════════
const DISHES = [

// ══════════════════════════
// KENYAN MAINS
// ══════════════════════════
{id:1,name:"Ugali",origin:"Kenyan Staple",emoji:"🌽",cat:"kenyan",tags:["kenyan","veg"],
 img:"https://images.unsplash.com/photo-1509509038570-3f31977e2eb2?w=800&q=80&fit=crop",
 prep:"5 min",cook:"15 min",serves:"4",diff:"Easy",featured:true,country:"Kenya",
 desc:"Kenya's undisputed national dish — a stiff, dense white cornmeal porridge served at almost every meal. Scooped by hand to mop up stews and greens, ugali forms the hearty backbone of Kenyan cuisine across all 42 tribes.",
 ingr:["2 cups white maize flour (unga wa ugali)","4 cups water","1 tsp salt","Extra flour for adjusting"],
 steps:["Bring 4 cups of water and salt to a vigorous boil in a heavy-bottomed pot over high heat.","Gradually pour in half the maize flour in a steady stream while stirring vigorously with a wooden spoon to prevent lumps.","Reduce heat to medium. Keep stirring firmly for 2 minutes.","Gradually fold in the remaining flour, pressing it into the mixture against the pot sides.","Continue stirring and turning the ugali for 8–10 minutes until it forms a smooth, stiff ball that pulls cleanly away from the pot.","Turn out onto a plate. It should hold its shape and be smooth and dense.","Serve hot with sukuma wiki, beef stew, omena, or any sauce."],
 tips:"Never stop stirring — constant motion prevents lumps. Authentic ugali should be so thick a wooden spoon stands upright in it. Use unga wa ugali (white maize flour) for the most authentic taste."},

{id:2,name:"Nyama Choma",origin:"Grilled Meat",emoji:"🍖",cat:"kenyan",tags:["kenyan","street"],
 img:"https://images.unsplash.com/photo-1544025162-d76694265947?w=800&q=80&fit=crop",
 prep:"20 min",cook:"60 min",serves:"4–6",diff:"Medium",featured:true,country:"Kenya",
 desc:"Kenya's beloved unofficial national dish — whole cuts of goat, beef or chicken slow-grilled over glowing charcoal until smoky and deeply tender. Minimally seasoned to let the meat speak. Always served with kachumbari and ugali at every celebration.",
 ingr:["1.5 kg goat leg/ribs or beef short ribs","2 tsp coarse sea salt","1 tsp freshly ground black pepper","1 tbsp vegetable oil","1 lemon, halved","Fresh rosemary sprigs (optional)","Kachumbari and ugali to serve"],
 steps:["Clean the meat thoroughly, leaving it on the bone for maximum flavour.","Rub all surfaces generously with coarse salt, black pepper and a drizzle of oil.","Prepare a charcoal grill — coals should be glowing orange with white ash, never flaming.","Place meat on the grill over medium-high heat. Do not rush this process.","Grill goat for 45–60 minutes, turning every 10–12 minutes and basting occasionally with fresh lemon juice.","The meat is ready when juices run clear, the outside is deeply charred and it is completely tender inside.","Rest for 10 minutes before chopping into pieces with a cleaver.","Serve on a wooden board or newspaper with kachumbari, ugali and a cold Tusker."],
 tips:"Real nyama choma uses only salt and pepper — never marinades. The secret is patience on the grill and quality charcoal. Goat is most traditional. Ask your butcher to leave the meat on the bone."},

{id:3,name:"Sukuma Wiki",origin:"Week-Pusher Greens",emoji:"🥬",cat:"kenyan",tags:["kenyan","veg"],
 img:"https://images.unsplash.com/photo-1576181256399-834e3b3a49bf?w=800&q=80&fit=crop",
 prep:"10 min",cook:"15 min",serves:"4",diff:"Easy",country:"Kenya",
 desc:"The most eaten vegetable dish in Kenya — collard greens sautéed with onions and tomatoes. The Swahili name 'week-pusher' reflects its role as the affordable everyday vegetable that stretches meals through the week. Simple, nutritious and endlessly satisfying.",
 ingr:["1 large bunch collard greens/kale, thinly sliced","2 tbsp vegetable oil","1 large onion, finely diced","2 ripe tomatoes, chopped","2 cloves garlic, minced","½ tsp mchuzi mix or stock cube","Salt and black pepper to taste"],
 steps:["Wash collard greens, strip tough stems, roll leaves tightly and slice very thinly (chiffonade style).","Heat oil in a wide pan over medium-high heat.","Add onions and fry until translucent and beginning to brown, about 5 minutes.","Add garlic and chopped tomatoes. Cook, stirring, for 3 minutes until tomatoes soften.","Add the sliced greens and toss to combine with the tomato-onion base.","Season with mchuzi mix, salt and pepper.","Stir-fry for 4–6 minutes until greens are tender but still vibrant green.","Serve immediately alongside ugali."],
 tips:"Don't overcook — sukuma should retain a slight bite and bright colour. Slice the greens as thinly as possible for the best texture. This dish wilts quickly so serve fresh."},

{id:4,name:"Githeri",origin:"Corn & Bean Stew",emoji:"🫘",cat:"kenyan",tags:["kenyan","veg"],
 img:"https://images.unsplash.com/photo-1547592180-85f173990554?w=800&q=80&fit=crop",
 prep:"15 min",cook:"55 min",serves:"5",diff:"Easy",country:"Kenya",
 desc:"An ancient Kikuyu staple and celebrated school-lunch icon — dried maize and beans slow-cooked together into a nourishing one-pot meal. Simple, filling and comforting. Githeri is so beloved it became a Kenyan internet meme when a photo of a man eating it went viral.",
 ingr:["1 cup dried maize kernels","1 cup dried red kidney beans","1 large onion, diced","2 tomatoes, chopped","2 tbsp vegetable oil","1 tsp curry powder","½ tsp paprika","½ stock cube","Salt, pepper","2 potatoes cubed (optional)"],
 steps:["Soak both maize and beans separately overnight in cold water.","Drain and rinse well. Boil together in fresh water for 40–50 minutes until tender. Drain.","Heat oil in a separate pan. Fry onions until golden brown, about 6 minutes.","Add tomatoes and cook down for 5 minutes to form a thick sauce.","Stir in curry powder, paprika and stock cube.","Add cooked maize and beans. Stir well to combine.","Add cubed potatoes and a little water if using. Cook 10 more minutes.","Adjust seasoning and serve with chapati or on its own."],
 tips:"Githeri is even better the next day as the flavours develop and deepen. Add a splash of coconut milk for a richer, coastal-inspired version."},

{id:5,name:"Mukimo / Irio",origin:"Kikuyu Mountain Mash",emoji:"🥔",cat:"kenyan",tags:["kenyan","veg"],
 img:"https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=800&q=80&fit=crop",
 prep:"15 min",cook:"30 min",serves:"4",diff:"Easy",country:"Kenya",
 desc:"A Kikuyu celebration dish from the slopes of Mount Kenya — creamy mashed potatoes combined with green peas, sweet corn and leafy greens into a vibrant, nutritious mash. The green colour from the vegetables makes this visually striking.",
 ingr:["6 large potatoes, peeled and cubed","1 cup green peas (fresh or frozen)","1 cup sweet corn kernels","1 bunch spinach or pumpkin leaves, chopped","2 tbsp butter","Salt and pepper to taste","Warm milk (optional)"],
 steps:["Boil potatoes in salted water until fork-tender, about 15–18 minutes.","In the last 5 minutes, add the peas, corn, and chopped greens to the pot.","Drain everything well.","Mash together vigorously using a potato masher. Keep it rustic — do not blend.","Add butter and mix in. Add warm milk for extra creaminess if desired.","Season generously with salt and pepper.","The result should be a thick, green-speckled mash — colourful and earthy.","Serve with stewed beef, chicken, or nyama choma."],
 tips:"Pumpkin leaves are the most traditional choice for the greens. Irio uses beans instead of peas. The mash should be thick — not a smooth puree. Rustic texture is authentic."},

{id:6,name:"Kenyan Pilau",origin:"Spiced Celebration Rice",emoji:"🍚",cat:"kenyan",tags:["kenyan","coastal"],
 img:"https://images.unsplash.com/photo-1596560548464-f010549b84d7?w=800&q=80&fit=crop",
 prep:"20 min",cook:"55 min",serves:"6",diff:"Medium",featured:true,country:"Kenya",
 desc:"Kenya's festive rice dish — long-grain rice cooked with whole spices, deeply caramelised onions and tender meat. Rich, aromatic and dark brown in colour. The centrepiece of Kenyan weddings, Eid, Christmas and every important celebration.",
 ingr:["2 cups basmati rice","500g beef or chicken pieces","2 large onions, thinly sliced","4 cloves garlic, crushed","1-inch fresh ginger, grated","3 tbsp vegetable oil","4 cardamom pods","4 cloves","1 cinnamon stick","1 tsp cumin seeds","1 tsp black peppercorns","½ tsp turmeric","3 cups beef stock","Salt, fresh cilantro"],
 steps:["Wash rice until water runs clear. Soak 20 minutes then drain.","Heat oil in a large heavy pot. Add whole spices and fry 60 seconds until fragrant.","Add sliced onions and fry on medium-low heat for 20–25 minutes until very dark, mahogany-coloured — this is the secret to pilau's colour.","Add garlic and ginger. Stir 2 minutes.","Add meat and turmeric. Brown the meat on all sides for 5 minutes.","Pour in stock. Bring to boil then simmer uncovered 15 minutes.","Stir in drained rice. Mix gently once.","Return to boil then reduce to lowest heat. Cover tightly and steam 18–20 minutes without lifting the lid.","Check rice is cooked and liquid absorbed. Fluff gently. Garnish with cilantro.","Serve with kachumbari and cold yoghurt raita."],
 tips:"The key to authentic pilau is deeply browning the onions until they are dark mahogany — almost burnt looking. This is what gives the rice its signature dark colour and deep flavour."},

{id:7,name:"Beef Stew (Karanga)",origin:"Kenyan Braised Beef",emoji:"🥩",cat:"kenyan",tags:["kenyan"],
 img:"https://images.unsplash.com/photo-1547592180-85f173990554?w=800&q=80&fit=crop",
 prep:"15 min",cook:"65 min",serves:"5",diff:"Medium",country:"Kenya",
 desc:"The quintessential Kenyan home comfort food — tender braised beef with potatoes, carrots and tomatoes in a rich, spiced sauce. Every Kenyan household has their own version. Best mopped up with fresh chapati on a Sunday afternoon.",
 ingr:["700g beef, cubed","3 potatoes, cubed","2 carrots, sliced","1 large onion, diced","3 tomatoes, chopped","4 cloves garlic, minced","1 tsp ginger","2 tbsp oil","1 tsp curry powder","½ tsp turmeric, ½ tsp paprika","1 stock cube","2 cups water","Salt, pepper, fresh coriander"],
 steps:["Season beef generously with salt and pepper.","Heat oil in a heavy pot. Brown beef in batches until deeply seared. Remove and set aside.","In the same pot, fry onions until golden, 5 minutes.","Add garlic and ginger. Cook 1 minute.","Add tomatoes, curry powder, turmeric and paprika. Cook down 5 minutes.","Return beef. Add water and stock cube. Bring to boil.","Cover and simmer 30 minutes.","Add potatoes and carrots. Simmer 20 more minutes until all is tender.","Season and garnish with coriander. Serve with ugali, rice or chapati."],
 tips:"Searing the beef in batches is crucial — this builds the deep flavour base of the stew. Don't skip this step. The potatoes should be soft and absorbing the sauce."},

{id:8,name:"Kachumbari",origin:"Fresh Tomato Salsa",emoji:"🍅",cat:"kenyan",tags:["kenyan","veg"],
 img:"https://images.unsplash.com/photo-1476718406336-bb5a9690ee2a?w=800&q=80&fit=crop",
 prep:"10 min",cook:"0",serves:"4",diff:"Easy",country:"Kenya",
 desc:"Kenya's vibrant, essential condiment — a fresh relish of tomatoes, red onions, coriander and chilli. Tart, bright and spicy, it cuts through the richness of grilled meats. No nyama choma is ever complete without a generous side of kachumbari.",
 ingr:["3 large ripe tomatoes, finely diced","1 red onion, very finely diced","2 green chillies, finely sliced","Large handful fresh coriander, chopped","Juice of 1 lemon or lime","Salt to taste","½ tsp black pepper"],
 steps:["Dice tomatoes finely, removing excess liquid.","Soak diced red onion in cold salted water for 5 minutes to remove harshness. Drain and pat dry.","Combine tomatoes, drained onion, chillies and coriander in a bowl.","Add lemon juice, salt and pepper.","Toss gently. Taste and adjust seasoning.","Serve immediately — best fresh and at room temperature."],
 tips:"Soaking the red onion in salted water removes its raw bitterness while keeping the crunch. Never refrigerate kachumbari — it loses its vitality. Make fresh every time."},

{id:9,name:"Maharagwe",origin:"Kidney Bean Stew",emoji:"🫘",cat:"kenyan",tags:["kenyan","veg","coastal"],
 img:"https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=800&q=80&fit=crop",
 prep:"10 min",cook:"50 min",serves:"4",diff:"Easy",country:"Kenya",
 desc:"A deeply satisfying Kenyan bean stew — red kidney beans simmered in a rich, spiced tomato and coconut sauce. Hearty, economical and packed with protein. A beloved vegetarian main served with ugali, rice or chapati across Kenya.",
 ingr:["2 cups dried red kidney beans","1 large onion, diced","3 tomatoes, blended","3 cloves garlic","1 tsp ginger","200ml coconut milk","1 tsp curry powder","½ tsp cumin, ½ tsp paprika","2 tbsp oil","Salt to taste"],
 steps:["Soak beans overnight. Drain and boil in fresh water 40–50 minutes until tender. Drain, reserve some liquid.","Fry onions in oil until golden brown.","Add garlic and ginger. Cook 2 minutes.","Add blended tomatoes, curry powder, cumin and paprika. Simmer 8 minutes.","Add cooked beans and coconut milk. Stir.","Add reserved bean liquid to adjust consistency.","Simmer 15 minutes until sauce is thick and coats beans.","Season and serve with rice or chapati."],
 tips:"Adding a tablespoon of coconut cream at the end enriches the sauce. Mashing a few beans against the pot naturally thickens the stew."},

{id:10,name:"Omena (Silver Fish)",origin:"Lake Victoria Specialty",emoji:"🐟",cat:"kenyan",tags:["kenyan"],
 img:"https://images.unsplash.com/photo-1467003909585-2f8a72700288?w=800&q=80&fit=crop",
 prep:"15 min",cook:"20 min",serves:"4",diff:"Easy",country:"Kenya",
 desc:"Beloved dried silver fish from Lake Victoria — rich in calcium and protein. A staple of western Kenya among the Luo and Luhya communities. Fried with tomatoes and onions into a pungent, intensely flavoured dish that pairs perfectly with ugali.",
 ingr:["2 cups dried omena (silver cyprinid)","2 tomatoes, diced","1 large onion, diced","3 cloves garlic, minced","1 green chilli","1 tbsp oil","½ tsp turmeric","Salt to taste","Fresh coriander"],
 steps:["Rinse omena in cold water 2–3 times. Soak in warm water 5 minutes then drain.","Heat oil. Fry onions until golden.","Add garlic, chilli and turmeric. Cook 1 minute.","Add tomatoes and cook down 5 minutes into a thick sauce.","Add drained omena. Stir gently to combine.","Cook on medium heat, stirring occasionally, for 8–10 minutes.","Season and garnish with coriander. Serve with ugali."],
 tips:"Omena have a strong smell — rinse them very well before cooking. The shorter you cook them, the more texture they retain."},

{id:11,name:"Matoke",origin:"Green Banana Stew",emoji:"🍌",cat:"kenyan",tags:["kenyan","veg"],
 img:"https://images.unsplash.com/photo-1571055107559-3e67626fa8be?w=800&q=80&fit=crop",
 prep:"15 min",cook:"40 min",serves:"4",diff:"Medium",country:"Kenya",
 desc:"A beloved East African staple — unripe green bananas cooked into a rich, starchy stew with tomatoes, onions and spices. The bananas soften as they cook, absorbing the spiced sauce into a wonderfully hearty dish.",
 ingr:["8 unripe green bananas, peeled","300g beef (optional)","2 tomatoes, diced","1 large onion, sliced","3 cloves garlic","1 tsp ginger","1 green chilli","1 tsp curry powder","½ tsp turmeric","2 tbsp oil","1.5 cups water or stock","Fresh coriander"],
 steps:["Peel green bananas (use gloves — they stain). Cut into chunks. Keep in salted water.","If using beef, brown in hot oil. Remove and set aside.","Fry onions until translucent. Add garlic, ginger and chilli. Cook 2 minutes.","Add tomatoes, curry powder and turmeric. Cook 5 minutes.","Add banana chunks and beef if using. Stir to coat.","Add stock or water — liquid should come halfway up the bananas.","Cover and simmer on low heat 25–30 minutes until bananas are very tender.","Mash a few bananas against the pot to thicken. Garnish with coriander."],
 tips:"Allow green bananas plenty of time to become completely tender. The longer they cook, the creamier the stew becomes."},

{id:12,name:"Nyama na Irio",origin:"Grilled Meat & Mash",emoji:"🥩",cat:"kenyan",tags:["kenyan"],
 img:"https://images.unsplash.com/photo-1544025162-d76694265947?w=800&q=80&fit=crop",
 prep:"20 min",cook:"30 min",serves:"4",diff:"Medium",country:"Kenya",
 desc:"A classic Kikuyu restaurant pairing — perfectly grilled beef or goat alongside a generous mound of irio. The combination of smoky, charred meat against creamy green mash is the definitive Kenyan comfort meal.",
 ingr:["600g beef steak or goat chops","Salt, pepper, garlic powder","2 sprigs rosemary","1 tbsp oil","Irio (mashed potatoes with peas and corn)","Kachumbari to serve"],
 steps:["Rub meat with salt, pepper, garlic powder and oil. Rest 15 minutes.","Heat a grill pan or charcoal grill to very high heat.","Grill steak 3–4 minutes per side for medium-rare or to preference.","Rest meat 5 minutes under foil before serving.","Prepare irio (see Mukimo recipe above).","Plate grilled meat alongside a generous scoop of irio.","Add kachumbari on the side."],
 tips:"For goat chops, cook longer on a medium-low heat to tenderise the meat. The irio should be freshly made and still warm."},

{id:13,name:"Ingoho (Luhya Chicken)",origin:"Luhya Braised Hen",emoji:"🐔",cat:"kenyan",tags:["kenyan"],
 img:"https://images.unsplash.com/photo-1588168333986-5078d3ae3976?w=800&q=80&fit=crop",
 prep:"20 min",cook:"90 min",serves:"6",diff:"Medium",country:"Kenya",
 desc:"A Luhya traditional delicacy from western Kenya — a free-range hen is slow-braised until falling off the bone in a richly spiced tomato sauce. Traditionally prepared when honouring a special guest, this dish represents the height of Luhya hospitality.",
 ingr:["1 large free-range hen or old chicken, cut up","2 large onions, diced","4 tomatoes, diced","4 cloves garlic","1 tsp ginger","2 tsp curry powder","½ tsp turmeric","2 cups water","2 tbsp oil","Salt, pepper, fresh coriander"],
 steps:["Brown chicken pieces in hot oil on all sides. Remove and set aside.","Fry onions in the same pot until deeply golden.","Add garlic, ginger, tomatoes, curry powder and turmeric. Cook 10 minutes.","Return chicken. Add water to come halfway up.","Cover and simmer on very low heat for 60–90 minutes until very tender.","Check regularly and add water as needed.","The final sauce should be thick and rich. Garnish with coriander and serve with ugali."],
 tips:"Free-range or older hens have more flavour but require longer cooking. The slow braising develops an incredible depth impossible with young supermarket chicken."},

// ══════════════════════════
// STREET FOOD
// ══════════════════════════
{id:14,name:"Chips Mayai",origin:"Fries Omelette",emoji:"🍟",cat:"street",tags:["street","kenyan"],
 img:"https://images.unsplash.com/photo-1586816001966-79b736744398?w=800&q=80&fit=crop",
 prep:"10 min",cook:"20 min",serves:"2",diff:"Easy",featured:true,country:"Kenya",
 desc:"Kenyan street food genius — crispy french fries embedded inside a fluffy egg omelette, flipped golden on both sides. A beloved Nairobi street meal found at every 'chips shop'. Served with kachumbari and chilli sauce. Filling, fast and endlessly satisfying.",
 ingr:["3 large potatoes, cut into chips","4 eggs","½ onion, diced","1 tomato, diced","1 green chilli, sliced","Salt and pepper","Oil for frying","Kachumbari to serve"],
 steps:["Deep-fry potato chips in hot oil until golden and very crispy. Drain and season with salt.","Beat eggs with a pinch of salt and pepper.","In an oven-safe pan, heat 1 tbsp oil over medium heat.","Sauté onion, tomato and chilli for 2 minutes.","Spread the crispy chips evenly over the pan.","Pour beaten egg over the chips — ensure egg fills all the gaps.","Cook on medium-low until the bottom sets and turns golden.","Place under a hot broiler for 3–4 minutes until the top is fully set.","Slide onto a board, cut into wedges and serve with kachumbari."],
 tips:"The chips MUST be crispy before adding the egg — soggy chips steam and create a soggy omelette. Very hot oil and proper draining is essential."},

{id:15,name:"Mutura",origin:"Kenyan Blood Sausage",emoji:"🌭",cat:"street",tags:["street","kenyan"],
 img:"https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=800&q=80&fit=crop",
 prep:"30 min",cook:"45 min",serves:"4–6",diff:"Hard",country:"Kenya",
 desc:"Kenya's legendary street sausage — goat or beef offal, minced meat and blood stuffed into intestine casings, boiled then grilled over charcoal. An acquired taste beloved by locals and increasingly by adventurous food lovers worldwide.",
 ingr:["500g minced beef or goat","200g offal (liver, heart), minced","150ml fresh blood","Goat intestines for casing, cleaned","1 large onion, minced","3 cloves garlic","1 tsp cumin","½ tsp pepper, ½ tsp chilli","1 tsp salt"],
 steps:["Thoroughly clean intestines — turn inside out, wash with water and vinegar multiple times.","Combine minced meat, offal, blood, onion, garlic, cumin, pepper, chilli and salt. Mix very well.","Tie off one end of the intestine firmly.","Carefully fill the casing firmly but not overstuffed. Tie off the other end. Pierce with a fork every 5cm.","Boil in salted water for 25–30 minutes until cooked through.","Transfer to a hot charcoal grill. Grill 10–15 minutes until the skin firms and browns.","Slice into rounds and serve with kachumbari."],
 tips:"Cleaning the intestines multiple times is the most critical step. The boil-then-grill method is essential for the right texture."},

{id:16,name:"Mahindi Choma",origin:"Roasted Corn",emoji:"🌽",cat:"street",tags:["street","veg","kenyan"],
 img:"https://images.unsplash.com/photo-1531171673193-06ac6b843363?w=800&q=80&fit=crop",
 prep:"5 min",cook:"20 min",serves:"4",diff:"Easy",country:"Kenya",
 desc:"The most iconic Kenyan street food — whole corn cobs roasted over charcoal until kernels pop and char to a sweet, smoky crisp. Rubbed with chilli-lime salt by roadside vendors. Found on every Nairobi street corner from morning to midnight.",
 ingr:["4 corn cobs in husks","1 tsp chilli powder","1 tsp salt","½ tsp paprika","1 lemon, halved","Charcoal for grilling"],
 steps:["Peel back husks, remove silk, replace husks around corn.","Soak corn in cold water for 10 minutes to prevent burning and steam the kernels.","Place on charcoal grill over medium-high heat.","Turn every 3–4 minutes. Grill 15–20 minutes total.","The husks will char — this is correct. Kernels should be golden with black spots.","Peel back husks to expose corn.","Mix chilli powder, salt and paprika together.","Rub cut lemon over hot corn then sprinkle generously with chilli-salt mix. Eat immediately."],
 tips:"The chilli-lemon-salt combo is non-negotiable. Vendors sometimes grill without husks for more direct char and crunch. Eat while piping hot."},

{id:17,name:"Smokies Pasua",origin:"Split Smoked Sausage",emoji:"🌭",cat:"street",tags:["street","kenyan"],
 img:"https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=800&q=80&fit=crop",
 prep:"5 min",cook:"10 min",serves:"2",diff:"Easy",country:"Kenya",
 desc:"A beloved Nairobi street food — beef smokies split down the middle, grilled on a flat griddle and served in bread with tomato sauce and kachumbari. Fast, cheap and delicious. The 'pasua' split creates more surface area for char and flavour.",
 ingr:["4 beef smokies (smoked sausages)","2 bread rolls or hot dog buns","1 tbsp butter","Kachumbari","Tomato sauce / ketchup","Mustard (optional)"],
 steps:["Score smokies lengthwise down the centre without cutting all the way through — this is the 'pasua'.","Heat a flat griddle or pan over medium-high heat.","Place smokies split-side down first. Cook 3–4 minutes until the split opens and chars.","Turn and cook 2–3 minutes on the other side.","Toast buns on the same griddle with a little butter until golden.","Assemble: bread, smokie, kachumbari, tomato sauce.","Eat immediately — these are best piping hot."],
 tips:"The pasua cut is key — it creates more caramelised surface area. Serve on thick Kenyan bread for the most authentic experience."},

{id:18,name:"Rolex",origin:"Nairobi Egg Chapati Roll",emoji:"🌯",cat:"street",tags:["street","breakfast","kenyan"],
 img:"https://images.unsplash.com/photo-1567337710282-00832b415979?w=800&q=80&fit=crop",
 prep:"5 min",cook:"15 min",serves:"1",diff:"Easy",featured:true,country:"Kenya",
 desc:"A Nairobi street food institution — a freshly made chapati folded around a cooked egg omelette with vegetables. Fast, filling and customisable. The 'Rolex' name comes from 'Rolled Eggs'. The ultimate grab-and-go Nairobi breakfast.",
 ingr:["1 fresh chapati","2 eggs","¼ onion, diced","¼ tomato, diced","½ green chilli, sliced","Salt and pepper","1 tbsp oil","Kachumbari (optional)"],
 steps:["Beat eggs with salt. Add onion, tomato and chilli.","Heat oil in a flat pan over medium heat.","Pour egg mixture in, spreading into a thin, even layer.","While egg is still soft on top, place a freshly made chapati directly on top of the cooking egg.","Press gently so the egg adheres to the chapati.","Flip the whole thing — chapati is now on the bottom.","Cook 30 seconds more.","Slide onto a surface, add kachumbari or hot sauce if desired.","Roll tightly into a cylinder. Wrap in paper and eat immediately."],
 tips:"The genius of the Rolex is placing the chapati onto the half-cooked egg so they fuse together. This makes it portable without unravelling when you walk."},

{id:19,name:"Viazi Karai",origin:"Spiced Fried Potatoes",emoji:"🥔",cat:"street",tags:["street","snack","coastal"],
 img:"https://images.unsplash.com/photo-1551782450-a2132b4ba21d?w=800&q=80&fit=crop",
 prep:"10 min",cook:"20 min",serves:"4",diff:"Easy",country:"Kenya",
 desc:"A coastal Kenyan snack beloved across the country — whole small potatoes boiled until soft, then coated in a spiced turmeric batter and deep-fried. The result is a contrasting spiced crust with a fluffy interior. Sold hot at every coastal stall.",
 ingr:["500g small potatoes, boiled whole and cooled","1 cup gram flour (besan)","½ tsp turmeric","½ tsp cumin","½ tsp chilli powder","Salt to taste","Water for batter","Oil for deep frying","Tamarind sauce to serve"],
 steps:["Boil whole potatoes in salted water until just tender. Do not overcook. Cool completely.","Halve if large.","Whisk gram flour with turmeric, cumin, chilli and salt. Add water until a medium-thick batter forms.","Heat oil to 180°C.","Coat each potato in batter and fry in batches 3–4 minutes until deeply golden.","Drain and serve hot with tamarind sauce and green chutney."],
 tips:"Unlike bhajias with sliced raw potato, viazi karai uses whole pre-boiled potatoes — this gives a fluffy interior and crispy exterior."},

// ══════════════════════════
// COASTAL / SWAHILI
// ══════════════════════════
{id:20,name:"Kuku Paka",origin:"Coconut Chicken Curry",emoji:"🍗",cat:"coastal",tags:["coastal","kenyan"],
 img:"https://images.unsplash.com/photo-1574484284002-952d92456975?w=800&q=80&fit=crop",
 prep:"20 min",cook:"45 min",serves:"4",diff:"Medium",featured:true,country:"Kenya · Mombasa",
 desc:"A crown jewel of Swahili coastal cuisine — chicken first charcoal-grilled until smoky, then simmered in a luscious coconut milk curry. The grilling imparts a depth that makes this curry unforgettable. The definitive dish of the Kenyan coast.",
 ingr:["1 whole chicken, cut into pieces","400ml coconut milk","2 tomatoes, blended","1 large onion, finely diced","4 cloves garlic","1-inch ginger","2 green chillies","1 tsp turmeric, 1 tsp cumin, 1 tsp coriander powder, ½ tsp chilli powder","2 tbsp oil","Juice of 1 lime","Fresh cilantro"],
 steps:["Season chicken with salt, turmeric and lime juice. Marinate 30 minutes.","Grill or broil chicken over high heat until charred outside but not fully cooked, about 6 minutes per side. Set aside.","Fry onions in oil until golden, 8 minutes.","Add garlic, ginger and chillies. Cook 2 minutes.","Add blended tomatoes, cumin, coriander and chilli powder. Simmer 10 minutes.","Pour in coconut milk. Stir and bring to gentle simmer.","Add grilled chicken pieces. Submerge in the coconut curry.","Simmer 20–25 minutes until chicken is fully cooked and sauce coats it.","Garnish with cilantro. Serve with coconut rice or chapati."],
 tips:"The charring of the chicken before adding to the curry is non-negotiable — it adds smoke and depth that you cannot replicate any other way."},

{id:21,name:"Wali wa Nazi",origin:"Coastal Coconut Rice",emoji:"🥥",cat:"coastal",tags:["coastal","veg"],
 img:"https://images.unsplash.com/photo-1512058564366-18510be2db19?w=800&q=80&fit=crop",
 prep:"5 min",cook:"25 min",serves:"4",diff:"Easy",country:"Kenya · Coast",
 desc:"The fragrant, creamy rice of Kenya's Indian Ocean coast — long-grain rice cooked entirely in coconut milk for a subtle sweetness and rich flavour. The perfect companion to fish curry, kuku paka, or bean stew.",
 ingr:["2 cups long-grain or basmati rice","400ml coconut milk (1 can)","1.5 cups water","½ tsp salt","1 tsp cumin seeds (optional)","2 cardamom pods (optional)"],
 steps:["Wash rice 3–4 times until water runs clear. Soak 15 minutes then drain.","Combine coconut milk and water in a pot. Add salt and whole spices if using.","Bring to a gentle simmer over medium heat.","Add drained rice. Stir once to distribute.","Bring to boil then reduce to the very lowest setting.","Cover tightly and steam for 15–18 minutes without lifting the lid.","After 18 minutes, check water is absorbed and rice is fluffy.","Turn off heat. Rest covered 5 minutes. Fluff with a fork."],
 tips:"Do not stir rice after adding to coconut milk — stirring releases starch and makes it sticky. Low heat and patience are everything."},

{id:22,name:"Biryani ya Kuku",origin:"Swahili Chicken Biryani",emoji:"🍛",cat:"coastal",tags:["coastal","kenyan"],
 img:"https://images.unsplash.com/photo-1563379091339-03b21ab4a4f8?w=800&q=80&fit=crop",
 prep:"30 min",cook:"70 min",serves:"6",diff:"Hard",country:"Kenya · Mombasa",
 desc:"The grand Swahili coastal biryani — layered fragrant basmati rice with spiced chicken, saffron, fried onions, dried fruits and whole spices. A celebratory dish at coastal weddings and Eid, more richly spiced than pilau.",
 ingr:["2 cups basmati rice soaked 30 min","1 whole chicken cut into 8 pieces","2 cups yoghurt","3 large onions thinly sliced","4 tomatoes diced","Garlic-ginger paste (4 cloves + 1-inch)","Whole spices: 6 cardamom, 6 cloves, 2 cinnamon, 3 bay leaves","1 tsp turmeric, 1 tsp garam masala","½ tsp saffron soaked in 3 tbsp warm milk","¼ cup raisins and cashews","Fresh mint, coriander, ghee, oil"],
 steps:["Marinate chicken with yoghurt, garlic-ginger paste, turmeric, garam masala, salt for 2 hours.","Deep fry sliced onions until very dark golden and crispy (birista). Reserve half for garnish.","Cook marinated chicken with tomatoes in a heavy pot for 25–30 minutes until tender.","Parboil rice in heavily salted water with whole spices for 5 minutes. Drain at 70% cooked.","In greased pot, layer half the rice, all the chicken with sauce, remaining rice.","Drizzle saffron milk over top rice layer.","Top with fried onions, raisins, cashews, fresh mint and ghee.","Seal the pot tightly with foil under the lid. Cook on lowest heat 25–30 minutes (dum).","Open and serve with kachumbari and raita."],
 tips:"The 'dum' steam cooking is crucial — the rice finishes cooking in the meat's aromatic steam. Seal tightly and absolutely never lift the lid early."},

{id:23,name:"Pweza wa Nazi",origin:"Octopus Coconut Curry",emoji:"🐙",cat:"coastal",tags:["coastal"],
 img:"https://images.unsplash.com/photo-1559847844-5315695dadae?w=800&q=80&fit=crop",
 prep:"20 min",cook:"65 min",serves:"4",diff:"Hard",country:"Kenya · Mombasa",
 desc:"A jewel of Swahili coastal cuisine — octopus slow-cooked in a rich coconut milk curry with tomatoes, garlic and fragrant spices. Traditionally the octopus is tenderised on sun-dried rocks before cooking. A Mombasa delicacy.",
 ingr:["800g octopus, cleaned","400ml coconut milk","2 tomatoes diced","1 large onion","4 cloves garlic, 1-inch ginger","1 tsp turmeric, 1 tsp cumin, 1 tsp coriander","2 tbsp oil","Fresh coriander, lime juice","Salt, chilli"],
 steps:["Tenderise octopus by beating or freeze for 24 hours then thaw.","Boil octopus in salted water for 30–40 minutes until tender. Drain, cool, cut into pieces.","Fry onions until golden. Add garlic and ginger. Cook 2 minutes.","Add tomatoes and all spices. Cook 8 minutes.","Add octopus pieces. Stir to coat.","Pour in coconut milk. Simmer 15–20 minutes until sauce is thick.","Add lime juice. Garnish with coriander. Serve with wali wa nazi."],
 tips:"Getting the octopus truly tender before the curry is non-negotiable. Underdone octopus is rubbery. The boiling time is essential."},

{id:24,name:"Mahamri",origin:"Coastal Fried Dough",emoji:"🍩",cat:"coastal",tags:["coastal","breakfast","snack"],
 img:"https://images.unsplash.com/photo-1559620192-032c4bc4674e?w=800&q=80&fit=crop",
 prep:"20 min + 1hr rise",cook:"20 min",serves:"12–15",diff:"Medium",country:"Kenya · Coast",
 desc:"The sweet, pillowy fried bread of Kenya's Swahili coast — made with coconut milk and cardamom, deep-fried to a golden, airy puff. Traditionally eaten for breakfast with mbaazi wa nazi (pigeon peas in coconut milk) or sweet chai.",
 ingr:["3 cups all-purpose flour","7g instant yeast","3 tbsp sugar","½ tsp salt","½ tsp ground cardamom","¼ tsp turmeric (for colour)","200ml warm coconut milk","¼ cup warm water","Oil for deep frying"],
 steps:["Mix flour, yeast, sugar, salt, cardamom and turmeric together.","Add warm coconut milk and water. Mix to a smooth, soft dough.","Knead for 8 minutes until springy and smooth.","Cover with a damp cloth. Rise in a warm place for 1–1.5 hours until doubled.","Punch down. Divide into 12–15 equal balls.","Roll each ball about 1cm thick. Cut into quarters (triangles) — traditional mahamri shape.","Heat oil to 170°C. Deep fry in batches 2–3 minutes per side until puffed and golden.","Drain on paper towels. Serve warm with mbaazi or sweet milky tea."],
 tips:"The cardamom and coconut milk give mahamri their distinctive coastal flavour. Don't skip the rise — it's what makes them airy inside."},

{id:25,name:"Samaki wa Kupaka",origin:"Fish in Coconut Sauce",emoji:"🐟",cat:"coastal",tags:["coastal"],
 img:"https://images.unsplash.com/photo-1467003909585-2f8a72700288?w=800&q=80&fit=crop",
 prep:"20 min",cook:"30 min",serves:"4",diff:"Medium",country:"Kenya · Coast",
 desc:"A beautiful Swahili grilled fish dish — whole red snapper charcoal-grilled then basted generously with a rich coconut-tomato sauce called 'kupaka'. The charred fish against the creamy coconut sauce is extraordinary.",
 ingr:["2 whole red snapper or kingfish, cleaned","400ml coconut milk","2 tomatoes blended","4 cloves garlic, 1-inch ginger","1 tsp turmeric, 1 tsp cumin","1 green chilli","Juice of 1 lemon","Oil, salt, pepper"],
 steps:["Season fish with salt, pepper, turmeric and lemon juice. Marinate 15 minutes.","Grill fish over hot charcoal 5–6 minutes per side until charred and cooked through.","KUPAKA SAUCE: Blend garlic, ginger and chilli into a paste. Fry in oil 2 minutes.","Add blended tomato and cumin. Cook 5 minutes.","Add coconut milk. Simmer 10 minutes until thickened.","Baste the grilled fish generously with the kupaka sauce.","Return to grill for 2 minutes to caramelise the sauce.","Serve with wali wa nazi, fresh lime and kachumbari."],
 tips:"The fish MUST be charcoal-grilled — the smokiness is fundamental to this dish. The kupaka sauce is applied over the finished fish for contrast."},

{id:26,name:"Mbaazi wa Nazi",origin:"Coastal Pigeon Peas",emoji:"🟫",cat:"coastal",tags:["coastal","veg","breakfast"],
 img:"https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=800&q=80&fit=crop",
 prep:"10 min",cook:"50 min",serves:"4",diff:"Easy",country:"Kenya · Coast",
 desc:"A Swahili coastal classic — whole pigeon peas cooked low and slow in creamy coconut milk with spices. Simple, fragrant and deeply satisfying. Traditionally eaten for breakfast with mahamri on the coast.",
 ingr:["2 cups dried pigeon peas (mbaazi)","400ml coconut milk","1 onion, finely diced","2 cloves garlic","1 tsp turmeric, ½ tsp cumin","2 tbsp oil","Salt, fresh coriander"],
 steps:["Soak pigeon peas 4–6 hours or overnight. Drain.","Boil in fresh water for 30–40 minutes until tender. Drain.","Fry onions and garlic in oil until soft.","Add turmeric and cumin. Stir 1 minute.","Add cooked peas and coconut milk.","Simmer on medium-low 15 minutes, stirring occasionally.","Sauce should be thick and creamy. Season and garnish with coriander.","Serve with mahamri for breakfast, or rice for lunch."],
 tips:"This is traditionally a breakfast dish on the coast. The coconut milk reduces and thickens beautifully — do not add water."},

// ══════════════════════════
// BREAKFAST
// ══════════════════════════
{id:27,name:"Chapati",origin:"East African Layered Flatbread",emoji:"🫓",cat:"breakfast",tags:["breakfast","kenyan"],
 img:"https://images.unsplash.com/photo-1567337710282-00832b415979?w=800&q=80&fit=crop",
 prep:"30 min + rest",cook:"30 min",serves:"8–10",diff:"Medium",featured:true,country:"Kenya",
 desc:"One of the most loved foods in Kenya — a soft, flaky, multilayered flatbread richer than Indian chapati. Made with oil, not ghee. The golden rounds are the perfect partner for any Kenyan stew. Fridays and Sundays are chapati days in most Kenyan homes.",
 ingr:["3 cups all-purpose flour","1 tsp salt, 1 tsp sugar","1 tbsp vegetable oil","~1 cup warm water","Additional oil for layering and cooking"],
 steps:["Mix flour, salt, sugar. Add 1 tbsp oil and rub into flour.","Add warm water gradually and mix to a soft, smooth dough. Knead 8 minutes.","Drizzle 1 tsp oil over dough, cover with a damp cloth, and rest 30 minutes.","Divide into 8 balls. On an oiled surface, roll each ball into a very thin circle.","Drizzle a little oil on the surface. Fold in half, then in half again (triangle). Roll thin again.","Drizzle oil again and repeat the folding process — this creates layers.","Finally roll into a round circle about 3mm thick.","Cook on a dry, medium-hot pan 1–2 minutes until bubbles appear.","Drizzle a little oil, flip. Cook 1–2 minutes until golden spots appear.","While hot, clap between palms to separate the flaky layers. Serve immediately."],
 tips:"The oil-fold-roll technique repeated twice is what creates beautiful flaky layers. Don't skip it. Chapati hardens as it cools, so serve them immediately."},

{id:28,name:"Uji",origin:"Kenyan Fermented Porridge",emoji:"🥣",cat:"breakfast",tags:["breakfast","drink","kenyan"],
 img:"https://images.unsplash.com/photo-1517673132405-a56a62b18caf?w=800&q=80&fit=crop",
 prep:"12 hrs",cook:"15 min",serves:"4",diff:"Medium",country:"Kenya",
 desc:"Kenya's traditional morning porridge — thin, slightly sour millet or maize porridge with a characteristic fermented tang. Nourishing, warming and comforting. Served in clay pots, it's the breakfast of choice for millions of Kenyans.",
 ingr:["1 cup millet flour or maize flour","4 cups water","1 tbsp fermentation starter (yoghurt)","Sugar or honey to taste","Milk (optional)"],
 steps:["FERMENTATION: Mix flour with a little water to a thick paste. Add yoghurt as starter. Cover and leave at room temperature for 12–24 hours until slightly sour.","COOKING: Mix the fermented paste with 4 cups water, whisking until smooth and lump-free.","Cook over medium heat, stirring continuously, until the porridge thickens, about 10–12 minutes.","The uji should be thin and pourable — add more water if too thick.","Sweeten with sugar or honey. Add a splash of milk if desired.","Pour into cups and drink directly like a hot beverage."],
 tips:"The fermentation gives uji its unique sour flavour. 24 hours produces a more pronounced tang. Clay pots keep it warmer for longer."},

{id:29,name:"Mandazi",origin:"East African Doughnut",emoji:"🍩",cat:"snack",tags:["snack","breakfast","kenyan"],
 img:"https://images.unsplash.com/photo-1559620192-032c4bc4674e?w=800&q=80&fit=crop",
 prep:"15 min + rest",cook:"20 min",serves:"16–20",diff:"Easy",country:"Kenya",
 desc:"Kenya's most beloved fried snack — a slightly sweet, triangular fried dough that puffs up golden and airy. Less sweet than a Western doughnut, lightly spiced with cardamom. Eaten for breakfast with chai or as an afternoon snack across East Africa.",
 ingr:["3 cups all-purpose flour","½ cup sugar","½ tsp baking powder","½ tsp ground cardamom","2 eggs","¾ cup coconut or regular milk","2 tbsp melted butter","Pinch of salt","Oil for deep frying"],
 steps:["Mix flour, sugar, baking powder, cardamom and salt.","Beat eggs with milk and butter. Add to dry ingredients and mix to a soft, smooth dough.","Cover with a cloth and rest 30 minutes.","Divide dough into golf-ball sized portions.","Roll each into a circle about 5mm thick. Cut into quarters — the classic mandazi shape.","Heat oil to 170°C. Deep fry in batches 2–3 minutes per side until golden.","Drain on paper. Serve warm with chai."],
 tips:"Do not skip the resting time — it relaxes the gluten and produces puffier, softer mandazi. The cardamom is essential for the authentic flavour."},

{id:30,name:"Samosa",origin:"Spiced Pastry Triangles",emoji:"🥟",cat:"snack",tags:["snack","street","kenyan"],
 img:"https://images.unsplash.com/photo-1601050690597-df0568f70950?w=800&q=80&fit=crop",
 prep:"40 min",cook:"20 min",serves:"20 pcs",diff:"Medium",country:"Kenya",
 desc:"Indian-origin pastry that has become completely Kenyan — crispy triangular shells filled with spiced minced meat or vegetables, deep-fried to a blistered golden brown. Found everywhere from street stalls to five-star hotels.",
 ingr:["PASTRY: 2 cups flour, ¼ tsp salt, 4 tbsp oil, warm water","FILLING: 300g minced beef, 1 onion diced, 2 cloves garlic, 1 tsp ginger, 1 tsp cumin, 1 tsp coriander, ½ tsp chilli, ½ tsp garam masala, fresh coriander","Oil for deep frying"],
 steps:["PASTRY: Mix flour, salt and oil. Add warm water to form a firm dough. Knead 5 minutes. Rest 30 minutes.","FILLING: Brown mince in a dry pan. Add onion, garlic, ginger. Cook 5 minutes. Add all spices. Cool completely.","Divide dough into 10 balls. Roll each into a thin oval. Cut in half to make two semicircles.","Form each semicircle into a cone, sealing with water-flour paste.","Fill with a tablespoon of filling. Seal the top edge firmly.","Heat oil to 170°C. Deep fry in batches, turning, 4–5 minutes until golden.","Drain. Serve with chutney or lime."],
 tips:"The pastry must be thin. Work the cones firmly — any gaps will cause the samosa to burst during frying."},

{id:31,name:"Bhajias",origin:"Spiced Potato Fritters",emoji:"🥔",cat:"snack",tags:["snack","street","kenyan"],
 img:"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80&fit=crop",
 prep:"15 min",cook:"15 min",serves:"4",diff:"Easy",country:"Kenya",
 desc:"One of Kenya's most addictive street snacks — thinly sliced potatoes dipped in a heavily spiced gram flour batter and deep-fried until crispy. Served with madras chutney and hot chai. Street vendors can barely keep up with demand.",
 ingr:["4 medium potatoes, thinly sliced (2–3mm)","1.5 cups gram flour (besan)","½ tsp turmeric, 1 tsp cumin, ½ tsp chilli powder, 1 tsp coriander powder, ½ tsp ginger powder","2 tbsp fresh coriander","Water to make batter","Salt","Oil for deep frying"],
 steps:["Mix gram flour with all spices and salt. Add water gradually, whisking until a thick batter forms — should coat the back of a spoon.","Slice potatoes thinly and uniformly. Pat dry thoroughly.","Heat oil to 175°C.","Dip potato slices in batter, letting excess drip off.","Fry in batches, don't overcrowd. Cook 3–4 minutes until golden and crisp.","Drain. Serve immediately with mango chutney and ketchup."],
 tips:"Dry the potato slices thoroughly — any moisture makes the batter fall off. The batter must be thick enough to coat without sliding."},

{id:32,name:"Kaimati",origin:"Coastal Sweet Dough Balls",emoji:"🟡",cat:"snack",tags:["snack","coastal"],
 img:"https://images.unsplash.com/photo-1559620192-032c4bc4674e?w=800&q=80&fit=crop",
 prep:"10 min + 1hr rise",cook:"20 min",serves:"20–25",diff:"Medium",country:"Kenya · Coast",
 desc:"A Swahili coastal sweet — small round deep-fried dough balls soaked in a cardamom-scented sugar syrup. The Swahili answer to doughnuts. Crispy outside, pillowy inside and dripping in warm syrup. Made for Eid and celebrations.",
 ingr:["2 cups flour","7g instant yeast","2 tbsp sugar","½ tsp cardamom","Pinch of salt","Warm water","Oil for deep frying","SYRUP: 1 cup sugar, ½ cup water, ½ tsp cardamom"],
 steps:["Mix flour, yeast, sugar, cardamom, salt. Add warm water to form a soft sticky dough.","Cover and rise 1 hour until doubled.","SYRUP: Boil sugar and water until thin syrup forms. Add cardamom. Keep warm.","Heat oil to 170°C. Wet your hands. Drop small golf-ball sized rounds of dough into oil.","Fry in batches, turning constantly, 4–5 minutes until deeply golden all over.","Drain briefly then immediately drop hot kaimati into warm syrup.","Leave in syrup 2–3 minutes, turning to coat. Remove and serve."],
 tips:"Dropping kaimati directly from hot oil into warm syrup is crucial — the contrast helps syrup penetrate into the dough."},

{id:33,name:"Mabuyu",origin:"Baobab Candy",emoji:"🟣",cat:"snack",tags:["snack","street","kenyan"],
 img:"https://images.unsplash.com/photo-1490323914169-4b57e77f2e7c?w=800&q=80&fit=crop",
 prep:"10 min",cook:"5 min",serves:"many",diff:"Easy",country:"Kenya",
 desc:"Kenya's unique traditional sweet — seeds of the baobab tree coated in tangy pink sugar syrup with chilli. Crunchy, tart, sweet and addictive. Sold in paper cones at markets and bus stages across East Africa.",
 ingr:["1 cup baobab seeds","½ cup sugar","¼ cup water","Red food colouring","½ tsp citric acid or tartaric acid","Pinch chilli powder (optional)"],
 steps:["Ensure baobab seeds are clean and dry.","Combine sugar and water in a pan. Cook on medium heat until sugar dissolves.","Continue heating until syrup reaches 115°C (soft ball stage).","Add food colouring, citric acid and chilli if using.","Add baobab seeds and stir vigorously — syrup will crystallise and coat each seed.","Spread on lined tray to cool and separate.","Store in an airtight container."],
 tips:"The crystallisation happens very quickly when you add the seeds — have everything ready before the syrup is done."},

// ══════════════════════════
// DRINKS
// ══════════════════════════
{id:34,name:"Kenyan Chai",origin:"Kenyan Milk Tea",emoji:"☕",cat:"drink",tags:["drink","breakfast","kenyan"],
 img:"https://images.unsplash.com/photo-1556679343-c7306c1976bc?w=800&q=80&fit=crop",
 prep:"2 min",cook:"10 min",serves:"2",diff:"Easy",featured:true,country:"Kenya",
 desc:"The great Kenyan ritual — strong black tea brewed together with whole milk, sugar, ginger and cardamom into a deeply amber, silky hot drink. Served throughout the day from dawn to midnight. Life in Kenya revolves around chai.",
 ingr:["2 cups whole milk","1 cup water","2 tsp loose leaf black tea (Kenya AA or Brooke Bond)","2 tbsp sugar","1 tsp fresh ginger, sliced","2 cardamom pods, crushed"],
 steps:["Combine water, milk, ginger and cardamom in a small saucepan.","Bring to a gentle simmer over medium heat.","Add the black tea leaves directly into the simmering liquid.","Add sugar and stir.","Simmer on low heat for 3–4 minutes — do not boil hard.","When tea turns rich amber-brown and milk is fragrant, remove from heat.","Strain through a fine sieve into cups.","Serve very hot. Kenyans often keep chai in a thermos all day."],
 tips:"Real Kenyan chai has more milk than water. Simmering (not boiling) draws out full flavour without bitterness. Brooke Bond or Safari tea brands are traditional."},

{id:35,name:"Chai ya Tangawizi",origin:"Kenyan Ginger Tea",emoji:"🫚",cat:"drink",tags:["drink","kenyan"],
 img:"https://images.unsplash.com/photo-1556679343-c7306c1976bc?w=800&q=80&fit=crop",
 prep:"5 min",cook:"12 min",serves:"2",diff:"Easy",country:"Kenya",
 desc:"A warming medicinal variant of Kenyan chai with a bold ginger kick. Ginger root is simmered with the tea and milk for a spicy, invigorating drink beloved for cold days and sore throats. The tangawizi (ginger) is the undisputed star.",
 ingr:["2 cups whole milk","1 cup water","2 heaped tsp black tea","2-inch piece fresh ginger, grated","2–3 tbsp sugar","2 cloves (optional)","½ cinnamon stick (optional)"],
 steps:["Place ginger, cloves and cinnamon in a saucepan with water.","Bring to a boil and simmer 3 minutes to extract maximum ginger flavour.","Add milk, tea and sugar.","Simmer on low heat 5–6 minutes, stirring gently.","Tea should be deep amber and smell intensely of ginger.","Strain into cups. Serve piping hot."],
 tips:"Use fresh ginger, never powdered. The more you grate rather than slice, the more intense the flavour. This tea is used as a natural remedy for colds."},

{id:36,name:"Kenyan AA Coffee",origin:"Highland Coffee",emoji:"☕",cat:"drink",tags:["drink"],
 img:"https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=800&q=80&fit=crop",
 prep:"5 min",cook:"5 min",serves:"1",diff:"Easy",country:"Kenya · Nyeri Highlands",
 desc:"Kenyan coffee is regarded among the world's finest — grown in the highlands of Nyeri, Kirinyaga and Murang'a at high altitude, producing bright, winey, full-bodied beans with extraordinary blackcurrant notes. Kenya AA is one of the world's most prized grades.",
 ingr:["2 tbsp freshly ground Kenya AA coffee","200ml hot water at 92°C","Whole milk (optional)","Sugar to taste"],
 steps:["Grind Kenya AA beans just before brewing for maximum freshness.","Place filter in pour-over dripper. Add 2 tbsp ground coffee.","Pour a little hot water (92°C) to 'bloom' the coffee — wait 30 seconds.","Slowly pour remaining water in circular motions over grounds.","Total brew time: 3–4 minutes.","Serve black to experience the full winey, fruity notes.","Or serve with steamed whole milk as kahawa na maziwa."],
 tips:"Kenyan coffee is characterised by bright acidity, blackcurrant notes and full body. Brewing at 92°C (not boiling) prevents bitterness."},

{id:37,name:"Dawa Cocktail",origin:"Carnivore Restaurant Nairobi",emoji:"🍋",cat:"drink",tags:["drink"],
 img:"https://images.unsplash.com/photo-1513558161293-cdaf765ed2fd?w=800&q=80&fit=crop",
 prep:"5 min",cook:"0",serves:"1",diff:"Easy",country:"Kenya · Nairobi",
 desc:"Kenya's most famous cocktail, invented at the Carnivore Restaurant in Nairobi — Dawa means 'medicine' in Swahili. A refreshing mix of vodka, honey, lime and ice stirred with a honey-coated stick. The iconic Nairobi party drink.",
 ingr:["50ml vodka","Juice of 1.5 limes","1 tbsp warm honey","1 tsp sugar (optional)","Crushed ice","A dawa stick (honey stirring stick)"],
 steps:["Fill a short glass with crushed ice.","Pour vodka over ice.","Squeeze lime juice generously over the vodka.","Pour honey slowly over the back of a spoon to sweeten.","Add the dawa stick coated in honey and sugar.","Do not stir — the guest stirs their own drink with the dawa stick.","The balance of sour lime, sweet honey and clean vodka is the goal.","Garnish with a lime wedge. Serve cold."],
 tips:"The dawa stick makes this drink ceremonial. At the Carnivore they mix honey and brown sugar on the stick — you swirl it to customise your sweetness."},

{id:38,name:"Maziwa Lala",origin:"Soured Fermented Milk",emoji:"🥛",cat:"drink",tags:["drink","breakfast","kenyan"],
 img:"https://images.unsplash.com/photo-1550583724-b2692b85b150?w=800&q=80&fit=crop",
 prep:"24 hrs",cook:"0",serves:"varies",diff:"Easy",country:"Kenya",
 desc:"Kenya's traditional naturally fermented milk — raw whole milk left to sour at room temperature until thick, tangy and pleasantly acidic. Similar to a drinkable yoghurt. Refreshing on a hot day and packed with natural probiotics.",
 ingr:["1 litre fresh whole cow's milk","2 tbsp plain yoghurt as starter culture","Optional: pinch of salt"],
 steps:["Warm milk slightly to room temperature. Do not boil.","Pour into a clean clay pot or glass jar.","Add 2 tbsp of yoghurt as starter culture. Stir gently.","Cover with muslin cloth — do not seal airtight.","Leave at room temperature for 24 hours.","Taste — should be thick, creamy and pleasantly sour.","Refrigerate to stop further fermentation.","Serve cold in a glass."],
 tips:"Do not disturb milk during fermentation. In Kenya, clay pots are traditional — porous walls allow it to breathe and naturally cool."},

{id:39,name:"Mursik",origin:"Kalenjin Fermented Milk",emoji:"🏃",cat:"drink",tags:["drink","kenyan"],
 img:"https://images.unsplash.com/photo-1550583724-b2692b85b150?w=800&q=80&fit=crop",
 prep:"48 hrs",cook:"0",serves:"varies",diff:"Hard",country:"Kenya · Rift Valley",
 desc:"The sacred fermented milk of the Kalenjin people — the tribe of Kenya's greatest long-distance runners. Raw milk fermented in a dried gourd lined with charcoal ash, giving it a smoky, tangy, unique flavour. Famous as the fuel of marathon champions.",
 ingr:["2 litres fresh whole cow's milk","1 traditional sotet (dried gourd) or clean sealed container","Charcoal ash from burnt olive or cedar branch","Wooden stick for stirring"],
 steps:["Clean the gourd by swirling hot water inside. Add charcoal ash and coat the interior.","Pour fresh warm milk into the prepared gourd.","Seal and keep at room temperature for 24–48 hours to ferment.","Shake or stir the mursik twice daily during fermentation.","After 24 hours it will have separated and have a sour, smoky smell.","At 48 hours it will be fully fermented — thick and very tangy.","Drink cold from the gourd or a cup."],
 tips:"Authentic mursik requires a gourd and charcoal ash — the ash gives a mineral, smoky quality impossible to replicate otherwise. Kalenjin athletes drink it for energy before long runs."},

// ══════════════════════════
// INTERNATIONAL
// ══════════════════════════
{id:40,name:"Spaghetti Carbonara",origin:"Italian Classic",emoji:"🍝",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1621996346565-e3dbc646d9a9?w=800&q=80&fit=crop",
 prep:"10 min",cook:"20 min",serves:"4",diff:"Medium",featured:true,country:"Italy · Rome",
 desc:"The Roman original — no cream, no shortcuts. Silky spaghetti coated in a sauce of egg yolks, Pecorino Romano, guanciale (cured pork cheek) and black pepper. One of the world's most iconic pasta dishes, made from just five ingredients.",
 ingr:["400g spaghetti or rigatoni","200g guanciale or pancetta, cubed","4 large egg yolks + 1 whole egg","100g Pecorino Romano, finely grated","100g Parmesan, finely grated","2 tsp freshly cracked black pepper","Salt for pasta water"],
 steps:["Bring a large pot of heavily salted water to a rolling boil.","Fry guanciale in a dry cold pan over medium heat until golden and its fat has rendered. Remove from heat.","Combine egg yolks, whole egg, Pecorino and Parmesan in a bowl. Add cracked pepper. Mix well.","Cook pasta to al dente. Reserve 1 cup of starchy pasta water before draining.","Add hot drained pasta to the pan with guanciale (off the heat). Toss vigorously.","Add the egg-cheese mixture. Add pasta water tablespoon by tablespoon, tossing constantly until a creamy sauce coats every strand.","The residual heat cooks the eggs without scrambling them. Serve immediately with extra cheese and pepper."],
 tips:"The starchy pasta water is the secret ingredient — it emulsifies the sauce. Work fast and keep the pan off direct heat when adding eggs to avoid scrambling."},

{id:41,name:"Butter Chicken (Murgh Makhani)",origin:"Indian Curry",emoji:"🍗",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1565557623262-b51c2513a641?w=800&q=80&fit=crop",
 prep:"30 min + marinating",cook:"40 min",serves:"4",diff:"Medium",featured:true,country:"India · Punjab",
 desc:"The world's most beloved curry — tender chicken in a velvety, mildly spiced tomato and cream sauce. Created in the 1950s at a Delhi restaurant, it's now cooked on every continent. Rich, silky and deeply aromatic.",
 ingr:["800g chicken thighs, cubed","MARINADE: 200g yoghurt, 2 tsp cumin, 1 tsp turmeric, 1 tsp chilli powder, 2 tsp garam masala, garlic-ginger paste, salt","SAUCE: 2 tbsp butter, 1 large onion, 4 cloves garlic, 1-inch ginger, 400g crushed tomatoes, 200ml cream, 1 tsp fenugreek leaves (kasuri methi), 1 tsp sugar, 2 tbsp butter for finishing"],
 steps:["Mix all marinade ingredients. Add chicken and marinate for at least 4 hours or overnight.","Grill or bake marinated chicken at 220°C for 15–18 minutes until charred in places. Set aside.","SAUCE: Melt butter in a heavy pot. Cook onions until golden, 10 minutes.","Add garlic and ginger. Cook 2 minutes.","Add crushed tomatoes and all sauce spices. Simmer 15 minutes.","Blend sauce until very smooth. Return to pot.","Add cream, sugar, fenugreek leaves and grilled chicken. Simmer 10 minutes.","Finish with a knob of cold butter stirred in. Serve with naan or basmati rice."],
 tips:"Kasuri methi (dried fenugreek leaves) is the secret flavour in butter chicken — don't leave it out. Charring the chicken before adding to the sauce adds essential smoky depth."},

{id:42,name:"Tonkotsu Ramen",origin:"Japanese Noodle Soup",emoji:"🍜",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1569050467447-ce54b3bbc37d?w=800&q=80&fit=crop",
 prep:"30 min",cook:"4 hrs",serves:"4",diff:"Hard",country:"Japan · Fukuoka",
 desc:"Japan's most intense ramen — a deeply rich, milky-white pork bone broth that requires hours of vigorous boiling to extract maximum collagen and flavour. Topped with chashu pork, soft-boiled egg, nori and bamboo shoots.",
 ingr:["2 kg pork trotters/neck bones","400g ramen noodles","TARE (seasoning): soy sauce, mirin, sake","4 soft-boiled eggs, marinated in soy","4 slices chashu (braised pork belly)","Nori, bamboo shoots, spring onions, sesame, black garlic oil","Garlic, ginger, green onions for broth"],
 steps:["Blanch pork bones in boiling water for 10 minutes. Drain and scrub clean.","Place cleaned bones in a large pot with cold water. Bring to a rolling boil and maintain for 4 hours — vigorous boiling creates the white, creamy broth.","Add garlic, ginger and green onions for last hour of cooking.","Strain the broth. Season with tare (soy, mirin, sake to taste).","Cook ramen noodles per package instructions.","In a warm bowl, add a ladleful of hot broth seasoned with tare.","Add noodles. Top with chashu pork, halved soft-boiled egg, nori, bamboo shoots, spring onions.","Drizzle black garlic oil. Serve immediately."],
 tips:"The vigorous boiling is intentional — it creates the white, creamy emulsified broth. Low simmering produces a clearer but thinner broth."},

{id:43,name:"Sushi (Nigiri & Maki)",origin:"Japanese Sushi",emoji:"🍣",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1553621042-f6e147245754?w=800&q=80&fit=crop",
 prep:"45 min",cook:"25 min",serves:"4",diff:"Hard",country:"Japan",
 desc:"Japan's most refined culinary art — perfectly seasoned vinegared rice paired with sliced raw fish or vegetables. Nigiri features hand-pressed rice with a topping; maki are rice and filling rolled in nori seaweed. A celebration of minimalist perfection.",
 ingr:["2 cups Japanese short-grain rice","SUSHI VINEGAR: 4 tbsp rice vinegar, 2 tbsp sugar, 1 tsp salt","NIGIRI: 200g sashimi-grade salmon, 200g tuna, 200g yellowtail","MAKI: nori sheets, avocado, cucumber, cream cheese","Wasabi, pickled ginger, soy sauce to serve"],
 steps:["Wash rice 5 times until water runs clear. Cook with slightly less water than usual (firm rice needed).","Dissolve sugar and salt in rice vinegar. Fold into hot rice gently — do not mash.","Fan rice while folding to cool it quickly. Rice should be glossy and sticky.","NIGIRI: Slice fish at 45° angle, 5–6mm thick. Dab fingers with water. Shape 20–25g rice into an oval, dab wasabi, press fish on top.","MAKI: Place nori shiny-side down on a bamboo mat. Spread thin layer of rice. Add fillings in a line. Roll firmly using the mat.","Wet the knife and slice maki into 6–8 pieces.","Serve on a board with soy sauce, pickled ginger and wasabi."],
 tips:"Temperature is everything — sushi rice must be body temperature when served, not refrigerator cold. Use only sashimi-grade (very fresh) fish."},

{id:44,name:"Beef Tacos al Pastor",origin:"Mexican Street Taco",emoji:"🌮",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=800&q=80&fit=crop",
 prep:"30 min",cook:"30 min",serves:"4",diff:"Medium",country:"Mexico · Mexico City",
 desc:"Mexico's most iconic street food — spiced pork (or beef) marinated in achiote, guajillo chillies and pineapple, grilled until caramelised, served in small corn tortillas with onion, cilantro and salsa. The smell at street stalls is hypnotic.",
 ingr:["600g pork shoulder or beef, thinly sliced","MARINADE: 2 dried guajillo chillies (soaked), 1 tbsp achiote paste, 2 cloves garlic, 1 tsp cumin, ½ tsp oregano, 3 tbsp orange juice, 2 tbsp pineapple juice, salt, vinegar","Small corn tortillas","Fresh pineapple chunks, diced white onion, fresh cilantro, lime, salsa"],
 steps:["Blend all marinade ingredients until smooth. Marinate meat for at least 2 hours.","Grill on high heat or in a cast iron pan until caramelised and slightly charred, 3–4 minutes per side.","Chop meat into small pieces.","Warm corn tortillas on a dry pan or directly over a gas flame.","To assemble: 2 tortillas stacked, topped with meat, a piece of grilled pineapple, diced onion, cilantro and salsa.","Squeeze lime over the top. Eat immediately."],
 tips:"The double tortilla is traditional and prevents tacos from falling apart. Never overfill — a good taco is small enough to eat in two bites."},

{id:45,name:"Pizza Margherita",origin:"Neapolitan Pizza",emoji:"🍕",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1574071318508-1cdbab80d002?w=800&q=80&fit=crop",
 prep:"30 min + 24hr ferment",cook:"8 min",serves:"2 pizzas",diff:"Hard",country:"Italy · Naples",
 desc:"The original pizza — thin, blistered Neapolitan dough topped with San Marzano tomato sauce, fresh mozzarella and basil. Created in 1889 to honour Queen Margherita. Named after the Italian flag colours. Perfection in its simplicity.",
 ingr:["DOUGH: 500g 00 flour, 325ml cold water, 10g salt, 3g active yeast","TOPPING: 400g San Marzano tomatoes, crushed by hand, 250g fresh mozzarella fior di latte, fresh basil leaves, good quality olive oil, sea salt"],
 steps:["DOUGH: Mix flour and salt. Dissolve yeast in cold water. Combine slowly, mixing 15 minutes until smooth. Cold ferment in fridge 24–72 hours.","SAUCE: Crush canned San Marzano tomatoes by hand. Season with salt. No cooking needed.","Remove dough from fridge 2 hours before baking. Divide into 2 balls.","Preheat oven to maximum (260°C+) with a pizza stone or steel inside for at least 1 hour.","Stretch dough by hand into a 30cm round — never use a rolling pin.","Top with a thin layer of sauce. Tear mozzarella and distribute.","Bake 6–8 minutes until the crust is blistered and charred in places.","Immediately add fresh basil leaves and drizzle with olive oil."],
 tips:"Cold fermentation (24–72 hours) is the secret to a complex, digestible dough. Never use a rolling pin — it degasses the dough. A very hot oven is non-negotiable."},

{id:46,name:"Pad Thai",origin:"Thai Stir-Fried Noodles",emoji:"🍜",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1559314809-0d155014e29e?w=800&q=80&fit=crop",
 prep:"20 min",cook:"15 min",serves:"2",diff:"Medium",country:"Thailand · Bangkok",
 desc:"Thailand's most famous street noodle dish — flat rice noodles stir-fried in a hot wok with shrimp or tofu, eggs, bean sprouts and the sweet-sour-salty pad thai sauce. Garnished with crushed peanuts, lime and fresh chilli.",
 ingr:["200g flat rice noodles (soaked in cold water 30 min)","200g shrimp or firm tofu","3 tbsp tamarind paste","2 tbsp fish sauce","1 tbsp palm sugar or brown sugar","2 eggs","1 cup bean sprouts","3 spring onions","3 cloves garlic","2 tbsp vegetable oil","Crushed roasted peanuts, lime, dried chilli, fresh cilantro to serve"],
 steps:["Mix tamarind paste, fish sauce and sugar together — this is your pad thai sauce. Set aside.","Heat a wok over very high heat until smoking.","Add oil, then garlic. Stir 30 seconds.","Add shrimp or tofu. Stir-fry 2 minutes.","Add drained noodles. Toss and fry 1 minute.","Push everything to one side. Crack eggs in the space, scramble briefly then mix into noodles.","Pour pad thai sauce over everything. Toss vigorously over high heat 2 minutes.","Add bean sprouts and spring onions. Toss 30 seconds more.","Serve in a bowl topped with crushed peanuts, lime wedge, dried chilli and coriander."],
 tips:"Very high heat is essential — the wok must be smoking for proper char. Cook in small batches. Pad thai sauce should be balanced: sour, sweet and salty in equal measure."},

{id:47,name:"Green Thai Curry",origin:"Thai Coconut Curry",emoji:"🟢",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1455619452474-d2be8b1e70cd?w=800&q=80&fit=crop",
 prep:"15 min",cook:"25 min",serves:"4",diff:"Easy",country:"Thailand",
 desc:"Thailand's most aromatic curry — a fragrant, fiery green paste cooked in creamy coconut milk with chicken, Thai aubergines and fresh kaffir lime leaves. Bright green, bold and utterly fragrant.",
 ingr:["600g chicken breast, sliced","400ml coconut milk","2–3 tbsp green curry paste","1 tbsp fish sauce","1 tsp palm sugar","200g Thai aubergines or pea aubergines","4 kaffir lime leaves, torn","2 red chillies, sliced","Fresh Thai basil, rice to serve","1 tbsp vegetable oil"],
 steps:["Heat oil in a wok. Add green curry paste and fry for 2 minutes until fragrant.","Pour in half the coconut milk. Stir and cook until the oil separates from the sauce — about 5 minutes.","Add chicken pieces. Stir to coat with the curry paste.","Add remaining coconut milk, fish sauce, sugar and kaffir lime leaves.","Add aubergines. Simmer 12–15 minutes until chicken is cooked and aubergines tender.","Taste and adjust fish sauce (salt) and sugar (sweet).","Add red chillies and Thai basil. Remove from heat immediately — the basil wilts in 30 seconds.","Serve with jasmine rice."],
 tips:"Frying the curry paste in oil until fragrant before adding coconut milk is crucial — it blooms the aromatics. Don't add Thai basil until the very end."},

{id:48,name:"Croissant",origin:"French Viennoiserie",emoji:"🥐",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=800&q=80&fit=crop",
 prep:"2 days",cook:"20 min",serves:"12",diff:"Hard",country:"France · Paris",
 desc:"The pinnacle of French baking — tissue-thin layers of buttery pastry that shatters as you bite, revealing a honeycomb interior of flaky, airy layers. Made over two days through a technique of repeated folding and rolling called lamination.",
 ingr:["DOUGH: 500g strong bread flour, 10g salt, 70g sugar, 7g instant yeast, 300ml whole milk, 40g softened butter","BUTTER BLOCK: 250g high-quality European butter (84% fat)"],
 steps:["Make dough: Mix flour, salt, sugar, yeast. Add milk and 40g softened butter. Knead 8 minutes. Chill overnight.","Butter block: Beat butter into a 15x15cm square between baking paper. Refrigerate until firm but pliable.","Roll dough into a 30x30cm square. Place butter block in centre at 45°. Fold dough corners over butter like an envelope.","LAMINATION — Letter fold: Roll into a 60x20cm rectangle. Fold into thirds. Wrap and chill 30 minutes. Repeat 3 more times (4 folds total).","Roll dough 3mm thick. Cut into large triangles.","Roll each triangle from the wide base toward the tip, stretching gently as you roll.","Place on lined trays with tip tucked under. Prove 2–3 hours at room temperature until jiggly.","Brush gently with egg wash. Bake at 200°C for 18–20 minutes until deep golden."],
 tips:"The key is keeping everything cold — if the butter melts into the dough during lamination, the layers are lost. Work quickly and chill between every fold."},

{id:49,name:"Beef Burger",origin:"American Classic",emoji:"🍔",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=800&q=80&fit=crop",
 prep:"15 min",cook:"12 min",serves:"4",diff:"Easy",featured:true,country:"USA",
 desc:"The great American classic — a thick, juicy smashed beef patty with a caramelised crust, melted cheddar, lettuce, tomato and special sauce in a toasted brioche bun. Simple, iconic and deeply satisfying when done right.",
 ingr:["600g ground beef (80/20 fat ratio)","4 brioche buns","4 slices American cheddar","Butter for toasting buns","SAUCE: 2 tbsp mayo, 1 tbsp ketchup, 1 tsp mustard, 1 tsp pickle relish","Iceberg lettuce, tomato, red onion, pickle slices","Salt and pepper"],
 steps:["Divide beef into 4 x 150g balls. Do not overwork the meat — keep it loose.","Mix the sauce ingredients together. Set aside.","Heat a cast iron pan or griddle over VERY HIGH heat until smoking.","Season beef balls generously with salt and pepper.","Place in hot pan, immediately press down hard with a heavy spatula to form a thin patty.","Cook 2–3 minutes until a deep caramelised crust forms. Flip once.","Add cheddar slice immediately after flipping. Cover with a dome for 1 minute to melt.","Toast buns cut-side down in butter until golden.","Assemble: bottom bun, sauce, lettuce, tomato, patty with cheese, onion, pickle, top bun."],
 tips:"The smash technique creates a caramelised Maillard crust that no thick patty can achieve. Use 80/20 ground beef — the fat is flavour and prevents dryness."},

{id:50,name:"Chicken Tikka Masala",origin:"British-Indian Curry",emoji:"🍛",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1565557623262-b51c2513a641?w=800&q=80&fit=crop",
 prep:"20 min + marinate",cook:"35 min",serves:"4",diff:"Medium",country:"UK / India",
 desc:"The dish that became the unofficial national dish of Britain — tender charred chicken in a rich, mildly spiced tomato-cream sauce. Born in Bangladeshi-British restaurants, this vibrant orange curry is now beloved globally.",
 ingr:["700g chicken thighs, cubed","MARINADE: 200g yoghurt, 2 tsp garam masala, 1 tsp turmeric, 2 tsp cumin, 2 tsp coriander, 1 tsp chilli, garlic-ginger paste, salt","SAUCE: 1 large onion, 4 cloves garlic, 1-inch ginger, 400g tomato passata, 200ml cream, 2 tsp garam masala, 1 tsp paprika, 1 tsp cumin, 2 tbsp butter, sugar, salt"],
 steps:["Marinate chicken at least 4 hours. Grill or broil at high heat until charred and cooked. Set aside.","Fry onion in butter until deeply golden, 10 minutes. Add garlic and ginger. Cook 2 minutes.","Add all sauce spices and cook 1 minute.","Add tomato passata. Simmer 15 minutes until thickened.","Blend sauce until smooth. Return to pot.","Add cream, a pinch of sugar and the grilled chicken.","Simmer 10 minutes until sauce coats chicken.","Serve with basmati rice, naan and fresh coriander."],
 tips:"Charring the chicken is the non-negotiable step that differentiates tikka masala from a plain chicken curry. The char adds smoke and textural contrast."},

{id:51,name:"Vegetable Biryani",origin:"Indian Celebration Rice",emoji:"🍛",cat:"international",tags:["international","veg"],
 img:"https://images.unsplash.com/photo-1563379091339-03b21ab4a4f8?w=800&q=80&fit=crop",
 prep:"30 min",cook:"50 min",serves:"5",diff:"Hard",country:"India",
 desc:"India's magnificent layered rice dish — fragrant basmati rice layered with spiced mixed vegetables, saffron milk, fried onions, mint and ghee, then steam-cooked (dum) until everything melds into a breathtakingly aromatic celebration dish.",
 ingr:["2 cups basmati rice (soaked 30 min)","2 cups mixed vegetables (potato, carrot, peas, beans, cauliflower)","2 cups yoghurt","2 large onions, thinly sliced and fried golden","4 cloves garlic, 1-inch ginger (paste)","Whole spices: cardamom, cloves, cinnamon, bay leaves","1 tsp each: turmeric, garam masala, cumin, coriander","Saffron soaked in warm milk","Mint, coriander, ghee, oil"],
 steps:["Marinate vegetables in yoghurt, garlic-ginger paste, garam masala, turmeric and salt for 1 hour.","Fry onions until dark golden (birista). Reserve half for garnish.","Cook marinated vegetables in remaining onions for 15 minutes.","Parboil rice in heavily salted water with whole spices for 5 minutes. Drain at 70%.","Layer in a greased heavy pot: half rice, all vegetables, remaining rice.","Drizzle saffron milk over top. Add fried onions, mint, ghee.","Seal tightly. Cook on lowest heat 25 minutes (dum).","Serve with raita and kachumber."],
 tips:"The dum (steam) cooking is the soul of biryani. Seal the pot completely — the rice finishes in the vegetable steam and absorbs all the aromatic flavours."},

{id:52,name:"Hummus",origin:"Middle Eastern Dip",emoji:"🫘",cat:"international",tags:["international","veg"],
 img:"https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?w=800&q=80&fit=crop",
 prep:"10 min + soak overnight",cook:"60 min",serves:"6",diff:"Easy",country:"Middle East / Lebanon",
 desc:"The ancient Middle Eastern staple — creamy, smooth chickpea purée with tahini, lemon and garlic. Made from scratch with dried chickpeas and high-quality tahini, this bears no resemblance to store-bought versions. A revelation.",
 ingr:["250g dried chickpeas","½ tsp baking soda (for soaking)","150g high-quality tahini","Juice of 2 lemons","3 cloves garlic, crushed with salt","4–6 tbsp cold ice water","Salt to taste","Olive oil, paprika, parsley to serve"],
 steps:["Soak chickpeas overnight with baking soda in plenty of water.","Drain, cover with fresh water and boil until very tender — about 60 minutes. Some skins will come off, which is fine.","Drain but reserve cooking liquid. While still hot, blend chickpeas in a food processor for 3–4 minutes until very smooth.","Add tahini and blend for 2 more minutes.","Add crushed garlic, lemon juice and a pinch of salt. Blend.","With the machine running, add ice water tablespoon by tablespoon until the hummus is silky and light.","Taste for seasoning.","Serve in a wide bowl, spreading with the back of a spoon in a spiral. Drizzle olive oil, sprinkle paprika, add parsley and whole chickpeas."],
 tips:"Blending hot chickpeas while they're still warm and removing skins produces the smoothest, creamiest hummus. Ice water added at the end creates the fluffy texture."},

{id:53,name:"Chicken Shawarma",origin:"Middle Eastern Wrap",emoji:"🫔",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1529006557810-274b9b2fc783?w=800&q=80&fit=crop",
 prep:"20 min + marinate",cook:"30 min",serves:"4",diff:"Medium",country:"Middle East",
 desc:"The Middle East's most exported street food — spiced marinated chicken roasted until caramelised, sliced thin and wrapped in flatbread with garlic sauce, pickles and salad. Addictive, fragrant and endlessly satisfying.",
 ingr:["700g boneless chicken thighs","MARINADE: 1 tsp cumin, 1 tsp coriander, 1 tsp turmeric, 1 tsp paprika, ½ tsp cinnamon, ½ tsp allspice, ¼ tsp cayenne, juice of 1 lemon, 3 cloves garlic, 3 tbsp yoghurt, 3 tbsp olive oil, salt","GARLIC SAUCE (toum): 1 head garlic, 1 cup oil, lemon juice, salt","Flatbreads, tomato, cucumber, pickles"],
 steps:["Combine all marinade ingredients. Marinate chicken at least 4 hours.","TOUM: Blend garlic cloves with salt. With processor running, add oil in a very thin stream alternating with lemon juice until it becomes a thick white emulsion.","Roast marinated chicken at 220°C for 25–30 minutes until charred at edges.","Rest 5 minutes then slice thinly.","Warm flatbreads in a dry pan.","Assemble wraps: garlic sauce, sliced chicken, tomato, cucumber, pickles.","Roll tightly in foil. Eat immediately."],
 tips:"The marinade's allspice and cinnamon are what give shawarma its distinctive aroma. The toum garlic sauce is what elevates it — don't substitute with plain garlic mayo."},

{id:54,name:"Bibimbap",origin:"Korean Mixed Rice Bowl",emoji:"🍚",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1553163147-622ab57be1c7?w=800&q=80&fit=crop",
 prep:"30 min",cook:"30 min",serves:"2",diff:"Medium",country:"South Korea",
 desc:"Korea's beloved national dish — a bowl of steamed rice topped with individually seasoned namul vegetables, beef, a fried egg and gochujang (red chilli paste). Mix everything together vigorously before eating. The colour, texture and flavour contrasts are extraordinary.",
 ingr:["2 cups steamed short-grain rice","NAMUL: spinach, bean sprouts, carrots, zucchini, shiitake mushrooms (each seasoned individually with soy sauce, sesame oil, garlic)","200g thinly sliced beef marinated in soy, sesame, sugar, garlic, ginger","2 eggs, fried sunny side up","3 tbsp gochujang, 1 tsp sesame oil, 1 tsp honey, 1 tsp vinegar (for sauce)","Sesame seeds, sesame oil"],
 steps:["Prepare each namul: blanch or sauté each vegetable individually. Season each with soy sauce, sesame oil and garlic. Set each aside.","Cook marinated beef in a hot pan until caramelised. Set aside.","Mix gochujang sauce ingredients together.","Heat a stone bowl (dolsot) or regular bowl. Add sesame oil.","Add hot rice. Arrange namul, beef and fried egg beautifully around the bowl.","Add a spoonful of gochujang sauce on top.","Bring to the table. Mix everything together vigorously before eating — this is the correct way."],
 tips:"In a dolsot (stone bowl), the rice continues cooking and forms a crispy base called nurungji. This crunchy rice at the bottom is the most prized part."},

{id:55,name:"Pho Bo",origin:"Vietnamese Beef Noodle Soup",emoji:"🍲",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1582878826629-32b2a1aac997?w=800&q=80&fit=crop",
 prep:"30 min",cook:"4 hrs",serves:"4",diff:"Hard",country:"Vietnam · Hanoi",
 desc:"Vietnam's national soul food — a deeply complex, crystal-clear beef bone broth that has been gently simmered for hours with charred onion, ginger, star anise, cinnamon and cloves. Served with flat rice noodles and paper-thin raw beef that cooks in the hot broth.",
 ingr:["2 kg beef bones + 300g oxtail","200g raw sirloin, paper thin","CHARRED aromatics: 1 large onion halved, 4-inch ginger piece","SPICES: 3 star anise, 1 cinnamon stick, 4 cloves, 2 cardamom pods","Fish sauce, rock sugar, salt","Rice noodles (pho banh)","GARNISH: bean sprouts, Thai basil, lime, sliced chilli, hoisin sauce, sriracha"],
 steps:["Blanch bones in boiling water 10 minutes. Rinse thoroughly.","Char the onion halves and ginger directly over a gas flame or under a broiler until blackened.","Place bones and oxtail in a large pot. Cover with cold water. Bring to a gentle boil — never vigorous.","Toast whole spices in a dry pan until fragrant. Add to broth along with charred aromatics.","Simmer very gently for 4–6 hours, skimming fat every 30 minutes.","Strain broth through a fine sieve. Season with fish sauce, rock sugar and salt.","Cook rice noodles per instructions. Drain.","In bowls, add noodles, paper-thin raw beef. Ladle very hot broth over (it cooks the beef).","Serve with the garnish plate and sauces on the side."],
 tips:"Charring the onion and ginger is non-negotiable — it gives pho its signature deep amber colour and sweet caramelised flavour. The broth must be clear, not cloudy."},

{id:56,name:"Spanish Paella",origin:"Spanish Rice Dish",emoji:"🥘",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1534080564583-6be75777b70a?w=800&q=80&fit=crop",
 prep:"20 min",cook:"35 min",serves:"4–6",diff:"Medium",country:"Spain · Valencia",
 desc:"Spain's greatest rice dish — short-grain bomba rice cooked in saffron-infused stock in a wide flat pan with chicken, rabbit or seafood, developing the prized socarrat (crispy caramelised rice crust at the bottom). Made outdoors over wood fire in Valencia.",
 ingr:["2 cups bomba or short-grain rice","500g chicken thighs and drumsticks","300g prawns or mussels","1 large onion, diced","4 tomatoes, grated","4 cloves garlic","1 tbsp smoked paprika","Pinch of saffron soaked in warm water","4 cups hot chicken stock","Extra virgin olive oil, rosemary, salt","Fresh lemon to serve"],
 steps:["Heat olive oil in a wide, flat paella pan over high heat.","Brown chicken pieces on all sides until golden. Set aside.","Fry onion and garlic in the same pan until golden, 5 minutes.","Add grated tomatoes and paprika. Cook 8 minutes until very thick (sofrito).","Add rice to the pan. Stir to coat with the sofrito for 2 minutes.","Add hot stock and saffron water. Do not stir again.","Return chicken pieces. Add prawns on top.","Cook on medium-high heat 18–20 minutes until stock is absorbed.","In the last 2 minutes, increase heat briefly to create the socarrat (crispy bottom).","Remove from heat, cover with foil and rest 5 minutes. Serve with lemon."],
 tips:"Never stir paella after adding the stock — stirring creates a mushy risotto. The socarrat (caramelised bottom crust) is the hallmark of a well-made paella."},

{id:57,name:"Beef Pho Inspired Kenyan Soup",origin:"Fusion Kenyan-Vietnamese",emoji:"🍲",cat:"international",tags:["international","kenyan"],
 img:"https://images.unsplash.com/photo-1547592180-85f173990554?w=800&q=80&fit=crop",
 prep:"20 min",cook:"90 min",serves:"4",diff:"Medium",country:"Kenya Fusion",
 desc:"A Kenyan-inspired noodle soup taking cues from Vietnamese pho — deep beef bone broth spiced with East African pilau spices (cardamom, cloves, cinnamon), served over rice noodles with kachumbari-inspired garnish. The meeting of two world culinary traditions.",
 ingr:["1 kg beef bones and short ribs","Rice noodles or spaghetti","Pilau spices: 3 cardamom, 3 cloves, 1 cinnamon stick, 1 tsp black pepper","2 tomatoes, 1 onion, 4 cloves garlic, 1-inch ginger","Salt, fish sauce or soy sauce","Bean sprouts, fresh coriander, lime, sliced chilli","Kachumbari on the side"],
 steps:["Blanch beef bones 5 minutes, drain, rinse.","Char onion and tomatoes under the broiler until blackened.","Place bones in a pot with cold water. Bring to a gentle boil.","Add pilau spices and charred aromatics.","Simmer for 1.5–2 hours, skimming regularly.","Strain broth. Season with salt and soy sauce.","Cook noodles separately and drain.","Bowl: noodles, sliced beef from the bones, hot broth.","Serve with bean sprouts, coriander, lime, chilli and kachumbari."],
 tips:"This fusion concept celebrates how food traditions connect across the world. The pilau spices give this soup a distinctly East African character."},

{id:58,name:"Crème Brûlée",origin:"French Custard Dessert",emoji:"🍮",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1470124182917-cc6e71b22ecc?w=800&q=80&fit=crop",
 prep:"15 min",cook:"40 min + chill",serves:"6",diff:"Medium",country:"France",
 desc:"France's most theatrical dessert — an impossibly silky vanilla custard beneath a paper-thin, shatteringly caramelised sugar crust. The tap of the spoon through the glass-like sugar is one of the great pleasures of fine dining.",
 ingr:["500ml double cream","1 vanilla pod (split and scraped)","6 egg yolks","100g caster sugar","Extra caster sugar for the brûlée crust"],
 steps:["Preheat oven to 150°C.","Gently heat cream with vanilla pod and seeds until just simmering. Do not boil.","Whisk egg yolks with sugar until pale and slightly thickened.","Slowly pour the hot cream into the eggs while whisking constantly.","Strain through a fine sieve. Remove any foam from the surface.","Pour into 6 ramekins placed in a deep baking tray.","Pour boiling water into the tray to come halfway up the ramekins (bain-marie).","Bake 35–40 minutes until set with a very slight wobble in the centre.","Chill completely for at least 4 hours.","To serve: sprinkle an even thin layer of caster sugar on top. Caramelise with a blowtorch until deep amber and glass-like."],
 tips:"The custard should wobble like set jelly when removed from the oven — it firms as it chills. Caramelise the sugar quickly in one pass to avoid heating the custard beneath."},

{id:59,name:"Greek Salad (Horiatiki)",origin:"Greek Village Salad",emoji:"🥗",cat:"international",tags:["international","veg"],
 img:"https://images.unsplash.com/photo-1540420773420-3366772f4999?w=800&q=80&fit=crop",
 prep:"10 min",cook:"0",serves:"4",diff:"Easy",country:"Greece",
 desc:"Greece's iconic summer salad — chunky tomatoes, cucumbers, red onion, Kalamata olives and a thick slab of creamy feta cheese dressed with the best olive oil, dried oregano and nothing else. Simple and perfect.",
 ingr:["4 large ripe tomatoes, cut into large chunks","1 cucumber, cut into thick half-moons","1 red onion, thinly sliced","200g block of feta cheese (not crumbled)","100g Kalamata olives","2 tsp dried oregano","6 tbsp extra virgin olive oil","Salt to taste, black pepper"],
 steps:["Cut tomatoes into large irregular chunks. Place in a wide bowl.","Add cucumber chunks and thinly sliced red onion.","Add Kalamata olives.","Place the whole block of feta on top — this is the authentic Greek way, never crumbled.","Sprinkle dried oregano over everything.","Pour olive oil generously over the salad and feta.","Season with a little salt (the feta is salty) and black pepper.","Serve immediately with crusty bread to mop up the juices."],
 tips:"Use the best tomatoes you can find — this salad is only as good as its ingredients. The feta should be a whole slab, not crumbled. Never add vinegar — lemon or plain olive oil only."},

{id:60,name:"Miso Ramen",origin:"Japanese Miso Noodle Soup",emoji:"🍜",cat:"international",tags:["international"],
 img:"https://images.unsplash.com/photo-1569050467447-ce54b3bbc37d?w=800&q=80&fit=crop",
 prep:"20 min",cook:"30 min",serves:"2",diff:"Medium",country:"Japan · Sapporo",
 desc:"Sapporo's regional ramen gift to the world — a rich, warming broth of dashi, chicken or pork stock and white miso paste, loaded with corn, butter, spring onions and topped with chashu pork. The miso gives depth and umami without the 4-hour commitment of tonkotsu.",
 ingr:["800ml chicken or dashi stock","4 tbsp white miso paste","1 tbsp soy sauce","1 tsp sesame oil","200g ramen noodles","2 slices chashu pork or 200g ground pork stir-fried","Corn kernels, pat of butter, spring onions, nori, soft-boiled egg","1 tbsp sake, 1 tsp mirin"],
 steps:["Heat stock in a pot. Do not boil.","In a separate bowl, whisk miso paste with a ladleful of hot stock until smooth.","Add dissolved miso back to pot. Add soy sauce, sake, mirin, sesame oil.","Taste — should be deeply savoury. Adjust seasoning.","Cook ramen noodles per instructions. Drain.","In warm bowls, ladle hot miso broth.","Add noodles, sliced chashu pork, corn, nori, spring onions.","Top with a pat of butter (it melts into the broth). Add halved soft-boiled egg."],
 tips:"Never boil the broth after adding miso — high heat destroys the live cultures and changes the flavour. The butter melting into the broth is the Sapporo signature."},

{id:61,name:"Guacamole",origin:"Mexican Avocado Dip",emoji:"🥑",cat:"international",tags:["international","veg"],
 img:"https://images.unsplash.com/photo-1534483509719-3feaee7c30da?w=800&q=80&fit=crop",
 prep:"10 min",cook:"0",serves:"4",diff:"Easy",country:"Mexico",
 desc:"The original avocado dip — a deceptively simple combination of ripe avocados, lime juice, coriander, onion and jalapeño that requires perfect avocados and restraint. Made fresh and served immediately, it has no equal.",
 ingr:["3 ripe avocados","Juice of 2 limes","1 small white onion, very finely diced","2 jalapeños or serrano chillies, finely diced","Large handful fresh coriander, chopped","1 clove garlic, minced (optional)","1 tsp salt"],
 steps:["Halve avocados and remove stones. Scoop flesh into a bowl.","Add lime juice and salt immediately to prevent browning.","Using a fork, mash to your desired texture — leave some chunks for authentic texture.","Add finely diced onion, jalapeño, garlic and coriander.","Mix gently.","Taste and adjust with more lime or salt.","Serve within 30 minutes with corn tortilla chips or as a taco topping."],
 tips:"The avocados must be perfectly ripe — slightly soft when pressed. Never add sour cream or yoghurt to authentic guacamole. The avocado stone placed in the dip does NOT prevent browning — lime juice and plastic wrap touching the surface does."},

{id:62,name:"Risotto ai Funghi",origin:"Italian Rice Dish",emoji:"🍄",cat:"international",tags:["international","veg"],
 img:"https://images.unsplash.com/photo-1476124369491-e7addf5db371?w=800&q=80&fit=crop",
 prep:"15 min",cook:"30 min",serves:"4",diff:"Hard",country:"Italy · Milan",
 desc:"The northern Italian classic — Arborio rice cooked slowly by the absorption method with white wine, warm stock and finished with butter and Parmesan into a silky, flowing, perfectly al dente dish. Finished with a generous handful of sautéed porcini mushrooms.",
 ingr:["300g Arborio or Carnaroli rice","30g dried porcini + 200g fresh mushrooms","1 large shallot, diced","2 cloves garlic","150ml dry white wine","1 litre warm vegetable or chicken stock","60g cold butter (for mantecatura)","80g Parmesan, finely grated","2 tbsp olive oil","Thyme, salt, pepper"],
 steps:["Soak dried porcini in 300ml warm water 20 minutes. Drain, reserving liquid (strain it). Roughly chop.","Sauté fresh mushrooms in butter over high heat until golden. Season. Set aside.","Warm stock in a separate pot on medium heat.","Fry shallot and garlic in olive oil 3 minutes.","Add rice and toast for 2 minutes — it will become slightly translucent.","Add wine — sizzle and stir until absorbed.","Add warm stock one ladleful at a time, stirring constantly and allowing each addition to be absorbed before adding the next.","Continue 18 minutes until rice is al dente with a slight bite.","Remove from heat. Add porcini soaking liquid if desired. Add COLD butter and Parmesan. Beat vigorously (mantecatura) until silky.","Top with sautéed mushrooms, thyme, and more Parmesan."],
 tips:"The mantecatura (vigorous beating in cold butter off the heat) is the finishing technique that creates the silky, flowing texture. The rice should flow like lava."},

{id:63,name:"Dal Makhani",origin:"Punjabi Black Lentils",emoji:"🫘",cat:"international",tags:["international","veg"],
 img:"https://images.unsplash.com/photo-1585937421612-70a008356fbe?w=800&q=80&fit=crop",
 prep:"15 min + soak",cook:"4 hrs slow cook",serves:"6",diff:"Hard",country:"India · Punjab",
 desc:"India's greatest lentil dish — whole black lentils and kidney beans slow-cooked for hours in a tomato and cream sauce enriched with butter. The restaurant version uses a tandoor with live coals; at home, time and patience are the secret ingredients.",
 ingr:["1.5 cups whole black lentils (urad dal)","½ cup kidney beans","3 tbsp butter + 2 tbsp oil","2 large onions, diced","4 cloves garlic","1-inch ginger, grated","400g tomato passata","200ml cream","1 tsp cumin, 1 tsp coriander, 1 tsp garam masala","Kasuri methi (dried fenugreek), salt, chilli"],
 steps:["Soak lentils and beans overnight. Boil in fresh water for 45–60 minutes until very soft.","Fry onions in butter + oil until deeply golden, 15 minutes.","Add garlic, ginger, cumin, coriander. Cook 3 minutes.","Add tomato passata and chilli. Simmer 20 minutes until very thick.","Add cooked lentils and beans with some cooking water.","Simmer on the lowest heat for 2–3 hours, stirring frequently to prevent sticking.","Add cream and garam masala. Simmer 30 more minutes.","Add kasuri methi and a final knob of cold butter.","Serve with naan or rice, garnished with cream and coriander."],
 tips:"The hours of slow cooking are not optional — they develop the deep, smoky, buttery flavour. Traditional dal makhani simmers overnight. The longer it cooks, the better it tastes."}

]; // end DISHES

// ════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════
let currentFilter = 'all';
let currentSearch = '';

// ════════════════════════════════════════════
//  FEATURED DISHES (render top picks)
// ════════════════════════════════════════════
function renderFeatured() {
  const fg = document.getElementById('featuredGrid');
  const featured = DISHES.filter(d => d.featured);
  fg.innerHTML = featured.map(d => `
    <div class="featured-card" onclick="goRecipe(${d.id})">
      <img src="${d.img}" alt="${d.name}" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1567337710282-00832b415979?w=800&q=80&fit=crop'">
      <div class="featured-card-overlay">
        <div class="featured-card-tag">${d.country}</div>
        <div class="featured-card-name">${d.name}</div>
        <div class="featured-card-desc">${d.desc.substring(0,90)}...</div>
        <div class="featured-card-btn">View Recipe →</div>
      </div>
    </div>
  `).join('');
}

// ════════════════════════════════════════════
//  FILTER & RENDER GRID
// ════════════════════════════════════════════
function filterCat(cat, btnEl) {
  currentFilter = cat;
  currentSearch = '';
  const searchInput = document.getElementById('searchInput');
  if (searchInput) searchInput.value = '';

  // Update nav buttons
  document.querySelectorAll('.nav-pill, .cat-chip').forEach(b => {
    b.classList.toggle('active', b.dataset.cat === cat);
  });

  renderGrid();
  scrollToGrid();
}

function getFilteredDishes() {
  let dishes = DISHES;
  
  if (currentFilter !== 'all') {
    const catMap = {
      kenyan: d => ['kenyan','street','coastal','breakfast','snack','drink'].includes(d.cat) && !d.tags.includes('international'),
      street: d => d.cat === 'street',
      coastal: d => d.cat === 'coastal',
      breakfast: d => d.cat === 'breakfast',
      snack: d => d.cat === 'snack',
      drink: d => d.cat === 'drink',
      international: d => d.cat === 'international',
      italian: d => d.country && d.country.toLowerCase().includes('italy'),
      indian: d => d.country && d.country.toLowerCase().includes('india'),
      japanese: d => d.country && d.country.toLowerCase().includes('japan'),
      mexican: d => d.country && d.country.toLowerCase().includes('mexico'),
      chinese: d => d.country && d.country.toLowerCase().includes('china'),
      thai: d => d.country && d.country.toLowerCase().includes('thailand'),
      french: d => d.country && d.country.toLowerCase().includes('france'),
      american: d => d.country && d.country.toLowerCase().includes('usa'),
      'middle-eastern': d => d.country && (d.country.toLowerCase().includes('middle east') || d.country.toLowerCase().includes('lebanon') || d.country.toLowerCase().includes('israel'))
    };
    const fn = catMap[currentFilter];
    if (fn) dishes = dishes.filter(fn);
  }

  if (currentSearch.trim()) {
    const s = currentSearch.toLowerCase();
    dishes = dishes.filter(d =>
      d.name.toLowerCase().includes(s) ||
      d.origin.toLowerCase().includes(s) ||
      d.desc.toLowerCase().includes(s) ||
      (d.country && d.country.toLowerCase().includes(s)) ||
      d.cat.includes(s) ||
      d.tags.some(t => t.includes(s))
    );
  }

  return dishes;
}

function renderGrid() {
  const container = document.getElementById('dishSections');
  const filtered = getFilteredDishes();
  const counter = document.getElementById('searchCount');
  
  if (counter) counter.textContent = `Showing ${filtered.length} of ${DISHES.length} recipes`;

  if (filtered.length === 0) {
    container.innerHTML = `
      <div class="no-results">
        <div class="no-results-emoji">🍽️</div>
        <div class="no-results-title">No recipes found</div>
        <p>Try a different search term or category</p>
      </div>
    `;
    return;
  }

  if (currentFilter === 'all' && !currentSearch.trim()) {
    // Grouped by category
    const groups = [
      {key:'kenyan', label:'🇰🇪 Kenyan Mains', emoji:'🥘', filterFn: d => ['kenyan'].includes(d.cat)},
      {key:'street', label:'🌽 Street Food', emoji:'🌽', filterFn: d => d.cat === 'street'},
      {key:'coastal', label:'🐚 Coastal & Swahili', emoji:'🐚', filterFn: d => d.cat === 'coastal'},
      {key:'breakfast', label:'🌅 Breakfast', emoji:'🌅', filterFn: d => d.cat === 'breakfast'},
      {key:'snack', label:'🥟 Snacks & Bites', emoji:'🥟', filterFn: d => d.cat === 'snack'},
      {key:'drink', label:'☕ Tea, Coffee & Drinks', emoji:'☕', filterFn: d => d.cat === 'drink'},
      {key:'international', label:'🌍 International Cuisine', emoji:'🌍', filterFn: d => d.cat === 'international'}
    ];

    container.innerHTML = groups.map(g => {
      const gDishes = DISHES.filter(g.filterFn);
      if (!gDishes.length) return '';
      return `
        <div class="section" id="sec-${g.key}">
          <div class="section-head">
            <span class="section-emoji">${g.emoji}</span>
            <h2 class="section-title">${g.label}</h2>
            <span class="section-count">${gDishes.length} recipes</span>
          </div>
          <div class="dish-grid">
            ${gDishes.map(renderCard).join('')}
          </div>
        </div>
        <hr class="section-divider">
      `;
    }).join('');
  } else {
    container.innerHTML = `
      <div class="section">
        <div class="dish-grid">
          ${filtered.map(renderCard).join('')}
        </div>
      </div>
    `;
  }
}

function renderCard(d) {
  const tags = d.tags.slice(0,3).map(t => `<span class="tag tag-${t}">${t.charAt(0).toUpperCase()+t.slice(1)}</span>`).join('');
  return `
    <div class="dish-card" onclick="goRecipe(${d.id})" role="article" aria-label="${d.name} recipe">
      <div class="dish-card-img-wrap">
        <img src="${d.img}" alt="${d.name} — ${d.origin}" loading="lazy"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div class="img-fallback" style="display:none">${d.emoji}</div>
        <div class="dish-card-origin">${d.country}</div>
      </div>
      <div class="dish-card-body">
        <div class="dish-card-tags">${tags}</div>
        <div class="dish-card-name">${d.name}</div>
        <div class="dish-card-origin-name">${d.origin}</div>
        <div class="dish-card-desc">${d.desc.substring(0,115)}...</div>
        <div class="dish-card-meta">
          <span>⏱ ${d.prep}</span>
          <span>🔥 ${d.cook}</span>
          <span>👥 ${d.serves}</span>
          <span>📊 ${d.diff}</span>
        </div>
        <button class="dish-card-btn">View Full Recipe →</button>
      </div>
    </div>
  `;
}

// ════════════════════════════════════════════
//  RECIPE PAGE ROUTER
// ════════════════════════════════════════════
function goRecipe(id) {
  const d = DISHES.find(x => x.id === id);
  if (!d) return;

  // Update URL hash
  window.location.hash = `/recipe/${id}`;

  // Build Schema.org JSON-LD for this recipe
  const schemaLD = {
    "@context": "https://schema.org/",
    "@type": "Recipe",
    "name": d.name,
    "description": d.desc,
    "image": d.img,
    "author": {"@type":"Person","name":"Ashraf's Cookbook"},
    "prepTime": `PT${d.prep.replace(' min','').replace(' hrs','H')}M`,
    "cookTime": `PT${d.cook.replace(' min','').replace(' hrs','H').replace('+','').replace(/[^0-9HM]/g,'')}M`,
    "recipeYield": d.serves,
    "recipeIngredient": d.ingr,
    "recipeInstructions": d.steps.map((s,i) => ({"@type":"HowToStep","text":s})),
    "recipeCuisine": d.country,
    "keywords": [d.name, d.origin, d.cat, 'recipe', d.country].join(', ')
  };

  // Get related dishes (same category, different dish)
  const related = DISHES.filter(x => x.cat === d.cat && x.id !== d.id).slice(0,4);

  const recipeHTML = `
    <script type="application/ld+json">${JSON.stringify(schemaLD)}<\/script>

    <div class="recipe-hero">
      <img src="${d.img}" alt="${d.name} — ${d.origin}" 
        onerror="this.style.display='none';this.nextElementSibling.style.background='linear-gradient(135deg, var(--navy), var(--navy-mid));this.nextElementSibling.style.display=&quot;flex&quot;;this.nextElementSibling.style.alignItems=&quot;center&quot;;this.nextElementSibling.style.justifyContent=&quot;center&quot;;this.nextElementSibling.style.fontSize=&quot;120px&quot;';this.nextElementSibling.textContent='${d.emoji}'">
      <div class="recipe-hero-overlay"></div>
      <div class="recipe-hero-content">
        <div class="recipe-breadcrumb">
          <a onclick="goHome()">Ashraf's Cookbook</a> ›
          <a onclick="filterCat('${d.cat}',null);goHome()">${d.cat.charAt(0).toUpperCase()+d.cat.slice(1)}</a> ›
          ${d.name}
        </div>
        <div class="recipe-main-tag">${d.country} · ${d.origin}</div>
        <h1 class="recipe-page-title">${d.name}</h1>
        <div class="recipe-page-subtitle">${d.origin}</div>
      </div>
    </div>

    <div class="recipe-body-wrap">
      <button class="recipe-back-btn" onclick="goBack()">← Back to Recipes</button>

      <div class="recipe-actions">
        <button class="action-btn action-btn-print" onclick="window.print()">🖨 Print Recipe</button>
        <button class="action-btn action-btn-save" onclick="saveRecipe(${d.id})">🔖 Save Recipe</button>
        <button class="action-btn action-btn-save" onclick="shareRecipe('${d.name}')">📤 Share</button>
      </div>

      <div class="recipe-meta-bar">
        <div class="recipe-meta-item">
          <div class="recipe-meta-icon">⏱</div>
          <div class="recipe-meta-val">${d.prep}</div>
          <div class="recipe-meta-label">Prep Time</div>
        </div>
        <div class="recipe-meta-item">
          <div class="recipe-meta-icon">🔥</div>
          <div class="recipe-meta-val">${d.cook}</div>
          <div class="recipe-meta-label">Cook Time</div>
        </div>
        <div class="recipe-meta-item">
          <div class="recipe-meta-icon">👥</div>
          <div class="recipe-meta-val">${d.serves}</div>
          <div class="recipe-meta-label">Serves</div>
        </div>
        <div class="recipe-meta-item">
          <div class="recipe-meta-icon">📊</div>
          <div class="recipe-meta-val">${d.diff}</div>
          <div class="recipe-meta-label">Difficulty</div>
        </div>
        <div class="recipe-meta-item">
          <div class="recipe-meta-icon">🌍</div>
          <div class="recipe-meta-val" style="font-size:13px">${d.country}</div>
          <div class="recipe-meta-label">Origin</div>
        </div>
      </div>

      <p class="recipe-desc-block">${d.desc}</p>

      <div class="recipe-two-col">
        <div class="ingr-card">
          <div class="recipe-section-title">🛒 Ingredients</div>
          <ul class="ingr-list">
            ${d.ingr.map(i => `
              <li class="ingr-item">
                <span class="ingr-dot"></span>
                <span>${i}</span>
              </li>
            `).join('')}
          </ul>
        </div>
        <div class="steps-card">
          <div class="recipe-section-title">👨‍🍳 Method</div>
          <ol class="steps-list">
            ${d.steps.map((s,i) => `
              <li class="step-item">
                <div class="step-num">${i+1}</div>
                <div class="step-text">${s}</div>
              </li>
            `).join('')}
          </ol>
          ${d.tips ? `
          <div class="tips-block">
            <div class="tips-title">💡 Chef's Tips</div>
            <div class="tips-text">${d.tips}</div>
          </div>` : ''}
        </div>
      </div>

      ${related.length ? `
      <div class="related-section">
        <div class="recipe-section-title" style="margin-bottom:20px">🍽 Related Recipes</div>
        <div class="related-grid">
          ${related.map(r => `
            <div class="related-card" onclick="goRecipe(${r.id})">
              <img class="related-card-img" src="${r.img}" alt="${r.name}"
                onerror="this.style.background='var(--mint-pale)';this.textContent='${r.emoji}'">
              <div class="related-card-body">
                <div class="related-card-name">${r.name}</div>
                <div class="related-card-cat">${r.origin} · ${r.diff}</div>
              </div>
            </div>
          `).join('')}
        </div>
      </div>` : ''}
    </div>
  `;

  document.getElementById('recipe-content').innerHTML = recipeHTML;
  document.getElementById('page-home').classList.remove('active');
  document.getElementById('page-recipe').classList.add('active');
  window.scrollTo({top:0, behavior:'smooth'});

  // Update page title and meta for SEO
  document.title = `${d.name} Recipe — Ashraf's Cookbook`;
  document.querySelector('meta[name="description"]').setAttribute('content', d.desc.substring(0,160));
}

function goHome() {
  document.getElementById('page-recipe').classList.remove('active');
  document.getElementById('page-home').classList.add('active');
  window.location.hash = '/';
  document.title = "Ashraf's Cookbook — Kenyan & World Cuisine Recipes";
}

function goBack() {
  goHome();
  setTimeout(() => scrollToGrid(), 100);
}

function scrollToGrid() {
  const anchor = document.getElementById('gridAnchor');
  if (anchor) anchor.scrollIntoView({behavior:'smooth', block:'start'});
}

function focusSearch() {
  goHome();
  setTimeout(() => {
    const inp = document.getElementById('searchInput');
    if (inp) { inp.focus(); inp.scrollIntoView({behavior:'smooth', block:'center'}); }
  }, 100);
}

function handleSearch(val) {
  currentSearch = val;
  currentFilter = 'all';
  document.querySelectorAll('.nav-pill, .cat-chip').forEach(b => {
    b.classList.toggle('active', b.dataset.cat === 'all');
  });
  clearTimeout(window._searchTimer);
  window._searchTimer = setTimeout(() => renderGrid(), 280);
}

function saveRecipe(id) {
  const saved = JSON.parse(localStorage.getItem('ashraf_saved') || '[]');
  if (!saved.includes(id)) {
    saved.push(id);
    localStorage.setItem('ashraf_saved', JSON.stringify(saved));
    alert('Recipe saved! 🔖');
  } else {
    alert('Already saved! 🔖');
  }
}

function shareRecipe(name) {
  if (navigator.share) {
    navigator.share({
      title: `${name} Recipe — Ashraf's Cookbook`,
      text: `Check out this recipe for ${name} on Ashraf's Cookbook!`,
      url: window.location.href
    });
  } else {
    navigator.clipboard.writeText(window.location.href).then(() => alert('Link copied! 📋'));
  }
}

// ════════════════════════════════════════════
//  HASH ROUTER
// ════════════════════════════════════════════
function handleHash() {
  const hash = window.location.hash;
  const recipeMatch = hash.match(/^#\/recipe\/(\d+)/);
  if (recipeMatch) {
    goRecipe(parseInt(recipeMatch[1]));
  } else {
    goHome();
  }
}

window.addEventListener('hashchange', handleHash);

// ════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  renderFeatured();
  renderGrid();
  document.getElementById('searchCount').textContent = `Showing all ${DISHES.length} recipes`;
  handleHash();
});
</script>
</body>
</html>
